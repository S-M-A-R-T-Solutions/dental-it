---
import { ArrowRight, Mail, Phone, MapPin } from "lucide-astro";

import {
    phoneNumber,
    phoneHref,
    email,
    emailHref,
    footerColumns,
    socialLinks,
} from "../../data/footer";

const currentYear = new Date().getFullYear();
---

<footer
    class="border-t border-(--footer-border) bg-(--footer-background) text-(--footer-foreground) transition-colors duration-200"
>
    <section class="relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0 opacity-20 dark:opacity-30">
        <div class="absolute -left-24 top-10 size-72 rounded-full bg-(--primary) blur-[120px]"></div>
        <div class="absolute -right-24 bottom-0 size-72 rounded-full bg-(--primary) blur-[140px]"></div>
        </div>

        <div class="site-container relative py-16 lg:py-20">
        <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
            <div>
            <p class="mb-4 text-sm font-black uppercase tracking-[0.22em] text-(--primary)">
                Dental IT Services in Miami, FL
            </p>

            <h2 class="max-w-3xl text-4xl font-black uppercase leading-[0.95] tracking-[-0.04em] text-(--footer-foreground) md:text-5xl lg:text-6xl">
                Secure, reliable IT support for modern dental practices.
            </h2>

            <p class="mt-5 max-w-2xl text-base leading-8 text-(--footer-muted) md:text-lg">
                Managed IT support, cybersecurity, HIPAA consulting, cloud backups,
                deployments, and technology solutions built specifically for dental
                offices in Miami and South Florida.
            </p>
            </div>

            <div class="rounded-4xl border border-(--footer-border) bg-(--footer-surface) p-6 shadow-[0_24px_70px_rgba(0,0,0,0.12)] backdrop-blur-xl md:p-8 dark:shadow-[0_24px_70px_rgba(0,0,0,0.22)]">
            <p class="text-sm font-black uppercase tracking-[0.2em] text-(--footer-muted)">
                Ready to improve your dental IT?
            </p>

            <h3 class="mt-3 text-2xl font-black text-(--footer-foreground)">
                Get a free IT assessment for your practice.
            </h3>

            <p class="mt-3 text-sm leading-7 text-(--footer-muted)">
                Let Dental IT review your current setup and identify opportunities
                to improve security, performance, backups, and support.
            </p>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                <a
                href="/contact"
                class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-6 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_16px_36px_rgba(239,35,49,0.28)] transition hover:-translate-y-0.5 hover:bg-(--primary-hover)"
                >
                Get Free IT Assessment
                <ArrowRight class="size-4" />
                </a>

                <a
                href={phoneHref}
                class="inline-flex items-center justify-center gap-2 rounded-full border border-(--footer-border) px-6 py-4 text-sm font-black uppercase tracking-wide text-(--footer-foreground) transition hover:border-(--primary) hover:text-(--primary)"
                >
                <Phone class="size-4" />
                {phoneNumber}
                </a>
            </div>
            </div>
        </div>
        </div>
    </section>

    <section class="border-t border-(--footer-border)">
        <div class="site-container py-12 lg:py-16">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.6fr]">
            <div>
            <a href="/" aria-label="Dental IT home page" class="inline-flex">
                <img
                src="/logo/logo-light-mode.webp"
                alt="Dental IT powered by SMART Solutions"
                class="h-14 w-auto dark:hidden"
                loading="lazy"
                decoding="async"
                />

                <img
                src="/logo/logo-dark-mode.webp"
                alt="Dental IT powered by SMART Solutions"
                class="hidden h-14 w-auto dark:block"
                loading="lazy"
                decoding="async"
                />
            </a>

            <p class="mt-5 max-w-sm text-sm leading-7 text-(--footer-muted)">
                Dental IT helps dental practices stay secure, compliant, backed up,
                and supported with technology services designed for the dental
                industry.
            </p>

            <div class="mt-6 space-y-3">
                <a
                href={phoneHref}
                class="flex items-center gap-3 text-sm font-bold text-(--footer-muted) transition hover:text-(--primary)"
                >
                <span class="inline-flex size-9 items-center justify-center rounded-full bg-(--footer-surface) text-(--primary)">
                    <Phone class="size-4" />
                </span>
                {phoneNumber}
                </a>

                <a
                href={emailHref}
                class="flex items-center gap-3 text-sm font-bold text-(--footer-muted) transition hover:text-(--primary)"
                >
                <span class="inline-flex size-9 items-center justify-center rounded-full bg-(--footer-surface) text-(--primary)">
                    <Mail class="size-4" />
                </span>
                {email}
                </a>

                <div class="flex items-center gap-3 text-sm font-bold text-(--footer-muted)">
                <span class="inline-flex size-9 items-center justify-center rounded-full bg-(--footer-surface) text-(--primary)">
                    <MapPin class="size-4" />
                </span>
                Miami, FL & South Florida
                </div>
            </div>

            <div class="mt-6 flex items-center gap-3">
                {
                socialLinks.map(({ label, href, icon: Icon }) => (
                    <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Visit Dental IT on ${label}`}
                    class="inline-flex size-11 items-center justify-center rounded-full border border-(--footer-border) bg-(--footer-surface) text-(--footer-foreground) transition hover:border-(--primary) hover:bg-(--primary) hover:text-white"
                    >
                    <Icon class="size-5" />
                    </a>
                ))
                }
            </div>
            </div>

            <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
            {
                footerColumns.map((column) => (
                <div>
                    <h3 class="text-sm font-black uppercase tracking-[0.2em] text-(--footer-foreground)">
                    {column.title}
                    </h3>

                    <ul class="mt-5 space-y-3">
                    {
                        column.links.map((link) => (
                        <li>
                            <a
                            href={link.href}
                            class="text-sm font-bold text-(--footer-muted) transition hover:text-(--primary)"
                            >
                            {link.label}
                            </a>
                        </li>
                        ))
                    }
                    </ul>
                </div>
                ))
            }
            </div>
        </div>
        </div>
    </section>

    <section class="border-t border-(--footer-border)">
        <div class="site-container flex flex-col gap-4 py-6 text-sm text-(--footer-muted) md:flex-row md:items-center md:justify-between">
        <p>
            © {currentYear} Dental IT. All rights reserved.
        </p>

        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
            <a href="/privacy-policy" class="transition hover:text-(--primary)">
            Privacy Policy
            </a>
            <a href="/terms-of-service" class="transition hover:text-(--primary)">
            Terms of Service
            </a>
            <a href="/contact" class="transition hover:text-(--primary)">
            Contact
            </a>
        </div>
        </div>
    </section>
</footer>
---
import Header from "../components/layout/Header.astro";

import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  theme?: "dark" | "light";
}

const {
  title = "Dental IT Services in Miami, FL | Managed IT Support for Dental Practices",
  description = "Dental IT provides managed IT services, cybersecurity, HIPAA compliance support, cloud backups, and technology solutions for dental practices in Miami and South Florida.",
  canonical,
  image = "/images/og/dental-it-miami-og.jpg",
  type = "website",
  noindex = false,
  theme = "dark",
} = Astro.props;

const siteName = "Dental IT";
const siteUrl = "https://itdental.tech";
const currentUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const absoluteImageUrl = new URL(image, siteUrl).toString();

const businessPhone = "+1-305-972-5760";
const businessPhoneDisplay = "(305) 972-5760";
const businessEmail = "info@itdental.tech";

const facebookUrl = "https://www.facebook.com/itdentaltech";
const instagramUrl = "https://www.instagram.com/itdentaltech/";

const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#localbusiness`,
      name: "Dental IT",
      alternateName: "Dental IT Powered by SMART Solutions",
      url: siteUrl,
      logo: `${siteUrl}/images/logo/dental-it-logo.png`,
      image: absoluteImageUrl,
      description:
        "Dental IT provides managed IT services, cybersecurity, HIPAA compliance support, cloud backups, monitoring, deployments, and technology solutions for dental practices in Miami and South Florida.",
      telephone: businessPhone,
      email: businessEmail,
      priceRange: "$$",
      areaServed: [
        {
          "@type": "City",
          name: "Miami",
          address: {
            "@type": "PostalAddress",
            addressLocality: "Miami",
            addressRegion: "FL",
            addressCountry: "US",
          },
        },
        {
          "@type": "AdministrativeArea",
          name: "South Florida",
        },
      ],
      address: {
        "@type": "PostalAddress",
        addressLocality: "Miami",
        addressRegion: "FL",
        addressCountry: "US",
      },
      contactPoint: {
        "@type": "ContactPoint",
        telephone: businessPhone,
        email: businessEmail,
        contactType: "customer support",
        areaServed: "US-FL",
        availableLanguage: ["English", "Spanish"],
      },
      sameAs: [facebookUrl, instagramUrl],
      makesOffer: [
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Managed IT Support for Dental Practices",
            serviceType: "Dental IT Support",
            areaServed: "Miami, FL",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "HIPAA Compliance IT Support",
            serviceType: "HIPAA Compliance",
            areaServed: "Miami, FL",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Dental Cybersecurity Services",
            serviceType: "Cybersecurity",
            areaServed: "Miami, FL",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Cloud Backups and Disaster Recovery",
            serviceType: "Cloud Backup",
            areaServed: "Miami, FL",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Dental Practice Technology Deployments",
            serviceType: "IT Deployment",
            areaServed: "Miami, FL",
          },
        },
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: siteName,
      description:
        "Managed IT services, cybersecurity, HIPAA compliance support, cloud backups, and technology solutions for dental practices in Miami and South Florida.",
      publisher: {
        "@id": `${siteUrl}/#localbusiness`,
      },
      potentialAction: {
        "@type": "SearchAction",
        target: `${siteUrl}/search?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
      inLanguage: "en-US",
    },
    {
      "@type": "WebPage",
      "@id": `${currentUrl}#webpage`,
      url: currentUrl,
      name: pageTitle,
      description,
      isPartOf: {
        "@id": `${siteUrl}/#website`,
      },
      about: {
        "@id": `${siteUrl}/#localbusiness`,
      },
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: absoluteImageUrl,
      },
      inLanguage: "en-US",
    },
  ],
};
---

<!doctype html>
<html lang="en" class={theme === "dark" ? "dark" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow, max-image-preview:large" />
      )
    }

    <link rel="canonical" href={currentUrl} />

    <meta name="author" content="Dental IT" />
    <meta name="publisher" content="Dental IT" />
    <meta
      name="keywords"
      content="Dental IT Miami, dental IT services Miami FL, managed IT support for dental offices, HIPAA IT support Miami, dental cybersecurity Miami, dental cloud backups, dental practice IT support, South Florida dental IT, IT support for dentists Miami, dental office cybersecurity"
    />

    <meta name="geo.region" content="US-FL" />
    <meta name="geo.placename" content="Miami" />
    <meta name="ICBM" content="25.7617, -80.1918" />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta
      property="og:image:alt"
      content="Dental IT services for dental practices in Miami, Florida"
    />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImageUrl} />

    <meta name="theme-color" content="#242424" />
    <meta
      name="color-scheme"
      content={theme === "dark" ? "dark light" : "light dark"}
    />

    <meta name="format-detection" content="telephone=yes" />
    <meta name="contact:phone_number" content={businessPhoneDisplay} />
    <meta name="contact:email" content={businessEmail} />

    <link rel="me" href={facebookUrl} />
    <link rel="me" href={instagramUrl} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/icons/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  </head>

  <body>
    <Header />
    <slot />
  </body>
</html>

---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

import "../styles/global.css";

import { siteConfig } from "../data/site";
import {
  getAbsoluteUrl,
  getCanonicalUrl,
  getPageTitle,
  getStructuredData,
} from "../utils/seo";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  theme?: "dark" | "light";
}

const {
  title = siteConfig.defaultTitle,
  description = siteConfig.defaultDescription,
  canonical,
  image = siteConfig.defaultImage,
  type = "website",
  noindex = false,
  theme = "dark",
} = Astro.props;

const pageTitle = getPageTitle(title);
const currentUrl = getCanonicalUrl(Astro.url.pathname, canonical);
const absoluteImageUrl = getAbsoluteUrl(image);

const structuredData = getStructuredData({
  currentUrl,
  pageTitle,
  description,
  absoluteImageUrl,
});
---

<!doctype html>
<html lang="en" class={theme === "dark" ? "dark" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow, max-image-preview:large" />
      )
    }

    <link rel="canonical" href={currentUrl} />

    <meta name="author" content="Dental IT" />
    <meta name="publisher" content="Dental IT" />
    <meta
      name="keywords"
      content="Dental IT Miami, dental IT services Miami FL, managed IT support for dental offices, HIPAA IT support Miami, dental cybersecurity Miami, dental cloud backups, dental practice IT support, South Florida dental IT, IT support for dentists Miami, dental office cybersecurity"
    />

    <meta name="geo.region" content="US-FL" />
    <meta name="geo.placename" content="Miami" />
    <meta name="ICBM" content="25.7617, -80.1918" />

    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta
      property="og:image:alt"
      content="Dental IT services for dental practices in Miami, Florida"
    />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImageUrl} />

    <meta name="theme-color" content="#242424" />
    <meta
      name="color-scheme"
      content={theme === "dark" ? "dark light" : "light dark"}
    />

    <meta name="format-detection" content="telephone=yes" />
    <meta name="contact:phone_number" content={siteConfig.business.phoneDisplay} />
    <meta name="contact:email" content={siteConfig.business.email} />

    <link rel="me" href={siteConfig.social.facebook} />
    <link rel="me" href={siteConfig.social.instagram} />

    <link rel="sitemap" href="https://itdental.tech/sitemap-index.xml" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/icons/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  </head>

  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

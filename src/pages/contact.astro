---
import MainLayout from "../layouts/MainLayout.astro";
import {
	ArrowRight,
	Mail,
	Phone,
	MapPin,
	ShieldCheck,
	MessageSquare,
	CheckCircle2,
} from "lucide-astro";

const contactHighlights = [
	"Dental-focused IT support for Miami and South Florida practices",
	"Managed IT, cybersecurity, backups, HIPAA consulting, and deployments",
	"Fast response for practices that cannot afford downtime",
];

const phoneNumber = "(305) 972-5760";
const phoneHref = "tel:+13059725760";
const email = "info@itdental.tech";
const emailHref = `mailto:${email}`;
---

<MainLayout
	title="Contact Dental IT | Free IT Assessment for Dental Practices in Miami"
	description="Contact Dental IT for managed IT support, cybersecurity, HIPAA consulting, cloud backups, deployments, and technology services for dental practices in Miami and South Florida."
	image="/images/og/dental-it-miami-home-og.jpg"
>
	<main class="overflow-hidden">
		<section class="relative isolate overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-52 top-16 h-136 w-136 rounded-full bg-(--primary)/18 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-152 w-152 rounded-full bg-(--primary)/14 blur-[170px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.08)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-30"
				>
				</div>

				<div
					class="parallax-layer absolute top-32 w-full max-w-none opacity-[0.18] blur"
					data-parallax-speed="-0.015"
					aria-hidden="true"
				>
					<img
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float absolute bottom-4 w-full max-w-none opacity-[0.28]"
					data-parallax-speed="0.02"
					aria-hidden="true"
				>
					<img
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/94 via-(--background)/58 to-(--background)/94"
				>
				</div>
			</div>

			<div
				class="site-container grid min-h-[calc(100vh-5rem)] items-center gap-12 py-16 md:py-20 lg:grid-cols-[0.92fr_1.08fr] lg:py-24"
			>
				<div class="relative z-10">
					<div
						class="glass-panel inline-flex max-w-full items-center gap-3 rounded-full px-4 py-2"
					>
						<span
							class="inline-flex size-2.5 shrink-0 rounded-full bg-(--primary) shadow-[0_0_18px_rgba(239,35,49,0.95)]"
						></span>

						<span
							class="text-xs font-black uppercase tracking-[0.18em] text-(--foreground) sm:tracking-[0.22em]"
						>
							Contact Dental IT
						</span>
					</div>

					<h1
						class="mt-7 max-w-4xl text-balance text-[clamp(2.35rem,5.5vw,4.75rem)] font-black leading-[0.95] tracking-tighter"
					>
						Get a free IT assessment for your dental practice.
					</h1>

					<p
						class="mt-7 max-w-2xl text-base leading-8 text-(--muted-foreground) sm:text-lg md:text-xl"
					>
						Tell us what your practice needs help with. Dental IT can review
						your current technology, identify risks, and help you plan a
						stronger IT environment for your team and patients.
					</p>

					<div class="mt-9 grid gap-3">
						{
							contactHighlights.map((item) => (
								<div class="flex items-start gap-3">
									<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
									<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
										{item}
									</p>
								</div>
							))
						}
					</div>

					<div class="mt-10 grid gap-4 sm:grid-cols-2">
						<a
							href={phoneHref}
							class="glass-panel glass-highlight rounded-4xl p-5 transition hover:-translate-y-1 hover:border-(--primary)"
						>
							<div class="relative flex items-start gap-4">
								<span
									class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary) text-white"
								>
									<Phone class="size-5" />
								</span>

								<div>
									<p class="text-sm font-black text-(--foreground)">
										Call us
									</p>
									<p class="mt-1 text-sm font-bold text-(--muted-foreground)">
										{phoneNumber}
									</p>
								</div>
							</div>
						</a>

						<a
							href={emailHref}
							class="glass-panel glass-highlight rounded-4xl p-5 transition hover:-translate-y-1 hover:border-(--primary)"
						>
							<div class="relative flex items-start gap-4">
								<span
									class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary) text-white"
								>
									<Mail class="size-5" />
								</span>

								<div>
									<p class="text-sm font-black text-(--foreground)">
										Email us
									</p>
									<p class="mt-1 text-sm font-bold text-(--muted-foreground)">
										{email}
									</p>
								</div>
							</div>
						</a>
					</div>

				</div>

				<div class="relative z-10">
					<div
						class="glass-panel glass-highlight rounded-4xl p-6 shadow-card sm:p-8 lg:p-10"
					>
						<div class="relative">

							<p
								class="section-eyebrow"
							>
								Send a Message
							</p>

							<h2
								class="mt-3 text-[clamp(1.85rem,3.5vw,3rem)] font-black leading-none tracking-tighter text-(--foreground)"
							>
								How can we help your practice?
							</h2>

							<p class="mt-4 text-sm leading-7 text-(--muted-foreground)">
								Complete the form and we will contact you to learn more about
								your dental practice technology needs.
							</p>

							<form
								name="contact"
								method="POST"
								data-netlify="true"
								netlify-honeypot="bot-field"
								action="/thank-you"
								class="mt-8 grid gap-5"
							>
								<input type="hidden" name="form-name" value="contact" />

								<p class="hidden">
									<label>
										Do not fill this out if you are human:
										<input name="bot-field" />
									</label>
								</p>

								<div class="grid gap-5 sm:grid-cols-2">
									<div>
										<label
											for="name"
											class="mb-2 block text-sm font-black text-(--foreground)"
										>
											Name
										</label>
										<input
											id="name"
											name="name"
											type="text"
											autocomplete="name"
											required
											placeholder="Your name"
										/>
									</div>

									<div>
										<label
											for="email"
											class="mb-2 block text-sm font-black text-(--foreground)"
										>
											Email
										</label>
										<input
											id="email"
											name="email"
											type="email"
											autocomplete="email"
											required
											placeholder="you@example.com"
										/>
									</div>
								</div>

                                <div class="grid gap-5 sm:grid-cols-2">
                                    <div>
                                        <label
                                            for="phone"
                                            class="mb-2 block text-sm font-black text-(--foreground)"
                                        >
                                            Phone Number
                                        </label>
                                        <input
                                            id="phone"
                                            name="phone"
                                            type="tel"
                                            autocomplete="tel"
                                            placeholder="(305) 000-0000"
                                        />
                                    </div>

                                    <div>
                                        <label
                                            for="best-time-to-call"
                                            class="mb-2 block text-sm font-black text-(--foreground)"
                                        >
                                            What is the best time for us to call you?
                                        </label>

                                        <select
                                            id="best-time-to-call"
                                            name="best-time-to-call"
                                            required
                                        >
                                            <option value="" disabled selected>Select a time window</option>
                                            <option value="Morning (8:00 am - 11:00 am)">
                                                Morning (8:00 am - 11:00 am)
                                            </option>
                                            <option value="Midday (11:00 am - 2:00 pm)">
                                                Midday (11:00 am - 2:00 pm)
                                            </option>
                                            <option value="Afternoon (2:00 pm - 5:00 pm)">
                                                Afternoon (2:00 pm - 5:00 pm)
                                            </option>
                                        </select>
                                    </div>
                                </div>

								<div>
									<label
										for="message"
										class="mb-2 block text-sm font-black text-(--foreground)"
									>
										Message
									</label>
									<textarea
										id="message"
										name="message"
										rows="6"
										required
										placeholder="Tell us about your practice, current IT needs, or the issue you want help with."
									></textarea>
								</div>

								<button
									type="submit"
									class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-8 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
								>
									Send Message
									<ArrowRight class="size-4" />
								</button>

								<p class="text-xs leading-6 text-(--muted-foreground)">
									By submitting this form, you agree to be contacted by Dental IT
									about your request.
								</p>
							</form>
						</div>
					</div>

					<div
						class="glass-panel glass-highlight mt-5 rounded-4xl p-5"
					>
						<div class="relative flex items-start gap-4">
							<span
								class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary)/15 text-(--primary)"
							>
								<ShieldCheck class="size-6" />
							</span>

							<div>
								<p class="text-sm font-black text-(--foreground)">
									Security-first conversations
								</p>
								<p class="mt-2 text-sm leading-7 text-(--muted-foreground)">
									Please avoid sending passwords, full patient records, or other
									sensitive data through this form.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<style>
		@keyframes networkFloat {
			0%,
			100% {
				translate: 0 0;
			}

			50% {
				translate: 0 -22px;
			}
		}

		@keyframes diffusePulse {
			0%,
			100% {
				transform: scale(1);
				opacity: 0.75;
			}

			50% {
				transform: scale(1.08);
				opacity: 1;
			}
		}

		.network-float {
			animation: networkFloat 9s ease-in-out infinite;
			will-change: translate, transform;
		}

		.diffuse-sphere {
			animation: diffusePulse 10s ease-in-out infinite;
			will-change: transform, opacity;
		}

		.diffuse-sphere-delay {
			animation-delay: -5s;
		}

		@media (prefers-reduced-motion: reduce) {
			.network-float,
			.diffuse-sphere {
				animation: none;
			}
		}
	</style>

	<script>
		const parallaxLayers = document.querySelectorAll("[data-parallax-speed]");
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

		const updateParallax = () => {
			if (reduceMotion.matches || window.innerWidth < 1024) return;

			const scrollY = window.scrollY;

			parallaxLayers.forEach((layer) => {
				const speed = Number(layer.getAttribute("data-parallax-speed") || 0);
				const y = scrollY * speed;

				layer.style.setProperty("--parallax-y", `${y}px`);
				layer.style.transform = `translate3d(0, var(--parallax-y), 0)`;
			});
		};

		const resetParallax = () => {
			parallaxLayers.forEach((layer) => {
				layer.style.removeProperty("--parallax-y");
				layer.style.transform = "";
			});
		};

		const handleParallax = () => {
			if (reduceMotion.matches || window.innerWidth < 1024) {
				resetParallax();
				return;
			}

			updateParallax();
		};

		handleParallax();

		window.addEventListener("scroll", handleParallax, { passive: true });
		window.addEventListener("resize", handleParallax);
	</script>
</MainLayout>
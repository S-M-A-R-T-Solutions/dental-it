---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import {
	ArrowRight,
	CheckCircle2,
	Search,
	ShieldCheck,
	Sparkles,
} from "lucide-astro";

import {
	heroHighlights,
	includedServices,
	whyChooseSeo,
	seoNeeds,
	seoTechnologyAreas,
	partnerTools,
	conversionItems,
	consultationItems,
} from "../../data/dental-seo-service";
---

<MainLayout
	title="SEO for Dental Practices in Miami, FL"
	description="Dental IT provides SEO for dental practices in Miami and South Florida, including technical SEO audits, keyword research, on-page optimization, Google Business Profile optimization, local SEO, content strategy, authority growth, and performance reporting."
	image="/images/og/dental-it-miami-home-og.jpg"
>
	<main class="overflow-hidden">
		<!-- HERO -->
		<section class="relative isolate overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="floating-card diffuse-sphere absolute -left-52 top-16 h-136 w-136 rounded-full bg-(--primary)/25 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="floating-card-alt diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-152 w-152 rounded-full bg-(--primary)/25 blur-[170px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.08)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-30"
				>
				</div>

				<div
					class="parallax-layer absolute top-40 w-full max-w-none opacity-[0.28] blur"
					data-parallax-speed="-0.015"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float absolute bottom-4 w-full max-w-none opacity-[0.35]"
					data-parallax-speed="0.025"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/92 via-(--background)/55 to-(--background)/94"
				>
				</div>
			</div>

			<div
				class="site-container grid min-h-[calc(100vh-5rem)] items-center gap-12 py-16 md:py-20 lg:grid-cols-[1.02fr_0.98fr] lg:py-24"
			>
				<div class="relative z-10">
					<div
						class="glass-panel inline-flex max-w-full items-center gap-3 rounded-full px-4 py-2"
					>
						<span
							class="inline-flex size-2.5 shrink-0 rounded-full bg-(--primary) shadow-[0_0_18px_rgba(239,35,49,0.95)]"
						></span>

						<span
							class="text-xs font-black uppercase tracking-[0.18em] text-(--foreground) sm:tracking-[0.22em]"
						>
							Dental Practice Solutions / Dental SEO
						</span>
					</div>

					<h1
						class="mt-7 max-w-5xl text-balance text-[clamp(2.4rem,5.8vw,5rem)] font-black leading-[0.95] tracking-tighter"
					>
						SEO for dental practices.
					</h1>

					<p
						class="mt-7 max-w-2xl text-base leading-8 text-(--muted-foreground) sm:text-lg md:text-xl"
					>
						Dental IT helps dental practices improve local search visibility,
						rank for high-value dental services, strengthen Google Business
						Profile performance, and turn organic traffic into appointment
						requests.
					</p>

					<div class="mt-9 flex flex-col gap-4 sm:flex-row">
						<a
							href="/contact"
							class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
						>
							Get Free SEO Consultation
							<ArrowRight class="size-4" />
						</a>

						<a
							href="#included"
							class="glass-panel inline-flex items-center justify-center gap-2 rounded-full px-7 py-4 text-sm font-black uppercase tracking-wide text-(--foreground) transition hover:-translate-y-1 hover:border-(--primary) hover:text-(--primary)"
						>
							Explore SEO Services
							<ArrowRight class="size-4" />
						</a>
					</div>

					<div class="mt-10 grid gap-3 sm:grid-cols-2">
						{
							heroHighlights.map((item) => (
								<div class="flex items-start gap-3">
									<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
									<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
										{item}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<div class="relative mx-auto hidden w-full max-w-xl lg:block lg:max-w-none">
					<div
						class="grid gap-5 sm:grid-cols-2 lg:block lg:min-h-136 xl:min-h-152"
					>
						<div
							class="parallax-layer floating-card lg:absolute lg:left-0 lg:-top-15 lg:w-[80%]"
							data-parallax-speed="0.04"
						>
							<div class="glass-panel rounded-4xl p-3">
								<Image
									src="/images/dental-seo-service/dental-seo-service-hero-1.webp"
									alt="Dental SEO analytics dashboard for local search visibility"
									width={900}
									height={1125}
									format="webp"
									quality="high"
									class="aspect-4/5 w-full rounded-3xl object-cover"
									loading="eager"
									decoding="async"
								/>
							</div>
						</div>

						<div
							class="parallax-layer floating-card-alt lg:absolute lg:-bottom-15 lg:-right-30 lg:w-[80%]"
							data-parallax-speed="-0.035"
						>
							<div class="glass-panel rounded-4xl p-3">
								<Image
									src="/images/dental-seo-service/dental-seo-service-hero-2.webp"
									alt="Dental practice local search results and SEO strategy planning"
									width={900}
									height={1125}
									format="webp"
									quality="high"
									class="aspect-4/5 w-full rounded-3xl object-cover"
									loading="eager"
									decoding="async"
								/>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTRO -->
		<section class="section-padding relative overflow-hidden bg-surface">
			<div
				class="absolute inset-0 bg-linear-to-br from-(--surface)/78 via-(--surface)/45 to-(--surface)/72 dark:from-black/78 dark:via-black/48 dark:to-black/82"
				aria-hidden="true"
			>
			</div>

			<div
				class="floating-card-alt diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-136 w-136 rounded-full bg-(--primary)/14 blur-[160px]"
				aria-hidden="true"
			>
			</div>

			<div
				class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.06)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-85"
				aria-hidden="true"
			>
			</div>

			<div class="site-container relative">
				<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
					<div>
						<p class="section-eyebrow">
							Boost Your Visibility & Patient Acquisition
						</p>

						<h2
							class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
						>
							Ranking higher can turn search visibility into real patient growth.
						</h2>

						<p class="section-description">
							In a competitive dental market, patients often start with Google.
							SEO helps your practice show up for the services and locations
							that matter most, so more high-intent visitors can discover your
							office and request an appointment.
						</p>

						<div class="mt-8 grid gap-3">
							{
								consultationItems.map((item) => (
									<div class="flex items-start gap-3">
										<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
										<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
											{item}
										</p>
									</div>
								))
							}
						</div>
					</div>

					<div class="glass-panel glass-highlight rounded-4xl p-6 sm:p-8 lg:p-10">
						<div class="relative">
							<Search class="size-10 text-(--primary)" />

							<h3 class="mt-6 text-2xl font-black tracking-tighter sm:text-3xl">
								Local SEO designed for dental search behavior.
							</h3>

							<p class="mt-5 text-base leading-8 text-(--muted-foreground)">
								Strong SEO connects your services, locations, website pages,
								Google Business Profile, and content strategy into a search
								presence that supports appointment growth.
							</p>

							<div class="mt-7 grid gap-4 sm:grid-cols-2">
								<div class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl">
									<p class="text-3xl font-black tracking-tighter text-(--primary)">
										Local
									</p>
									<p class="mt-2 text-sm font-bold leading-6 text-(--muted-foreground)">
										Optimize for city, service, and near-me searches.
									</p>
								</div>

								<div class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl">
									<p class="text-3xl font-black tracking-tighter text-(--primary)">
										Growth
									</p>
									<p class="mt-2 text-sm font-bold leading-6 text-(--muted-foreground)">
										Turn organic visibility into patient inquiries.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INCLUDED SERVICES -->
		<section
			id="included"
			class="section-padding relative overflow-hidden bg-site"
		>
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-48 top-[20%] h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="parallax-layer network-float absolute left-1/2 top-52 w-432 max-w-none -translate-x-1/2 opacity-[0.16]"
					data-parallax-speed="0.018"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/90 via-(--background)/58 to-(--background)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow justify-center">
						What Our SEO Optimization Service Includes
					</p>

					<h2
						class="section-title mx-auto normal-case text-[clamp(2rem,4.2vw,3.8rem)] leading-none"
					>
						Everything your dental practice needs to grow in organic search.
					</h2>

					<p class="section-description mx-auto">
						From technical audits and keywords to Google Business Profile,
						local SEO, content strategy, authority growth, and reporting, Dental
						IT helps build your online visibility with structure.
					</p>
				</div>

				<div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
					{
						includedServices.map(({ title, description, icon: Icon }) => (
							<article class="service-card group relative overflow-hidden rounded-4xl p-6 transition hover:-translate-y-1 hover:border-(--primary) md:p-7">
								<div class="absolute -right-12 -top-12 size-32 rounded-full bg-(--primary)/10 blur-2xl transition group-hover:bg-(--primary)/20" />

								<Icon class="relative size-10 text-(--primary)" />

								<h3 class="relative mt-6 text-lg font-black sm:text-xl">
									{title}
								</h3>

								<p class="relative mt-4 text-sm leading-7 text-(--muted-foreground)">
									{description}
								</p>
							</article>
						))
					}
				</div>

				<div class="mt-12 flex justify-center">
					<a
						href="/contact"
						class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
					>
						Get a Free Quote
						<ArrowRight class="size-4" />
					</a>
				</div>
			</div>
		</section>

		<!-- WHY CHOOSE -->
		<section class="section-padding relative overflow-hidden bg-surface">
			<div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
				<div
					class="absolute inset-0 bg-linear-to-br from-(--surface)/78 via-(--surface)/45 to-(--surface)/72 dark:from-black/78 dark:via-black/48 dark:to-black/82"
					aria-hidden="true"
				>
				</div>

				<div
					class="floating-card diffuse-sphere absolute -left-52 top-10 h-128 w-lg rounded-full bg-(--primary)/20 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="floating-card-alt diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-136 w-136 rounded-full bg-(--primary)/14 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.06)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-85"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/90 via-(--surface)/55 to-(--surface)/94"
					aria-hidden="true"
				>
				</div>
			</div>

			<div class="site-container relative z-10">
				<div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
					<div class="lg:sticky lg:top-32">
						<p class="section-eyebrow">Partners With the Best</p>

						<h2
							class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
						>
							Why choose Dental IT for dental SEO?
						</h2>

						<p class="section-description">
							SEO is not one task. It is a combination of technical fixes,
							local optimization, content strategy, reporting, authority growth,
							and ongoing improvement as search behavior changes.
						</p>

						<div class="mt-8">
							<a
								href="/contact"
								class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
							>
								Schedule Free Consultation
								<ArrowRight class="size-4" />
							</a>
						</div>
					</div>

					<div class="grid gap-5 md:grid-cols-2">
						{
							whyChooseSeo.map(({ title, description, icon: Icon }, index) => (
								<article
									class:list={[
										"glass-panel glass-highlight rounded-4xl p-6 md:p-7",
										index === whyChooseSeo.length - 1 && "md:col-span-2",
									]}
								>
									<div class="relative">
										<div class="flex size-12 items-center justify-center rounded-2xl bg-(--primary) text-white">
											<Icon class="size-6" />
										</div>

										<h3 class="mt-6 text-lg font-black uppercase tracking-tight sm:text-xl">
											{title}
										</h3>

										<p class="mt-4 text-sm leading-7 text-(--muted-foreground)">
											{description}
										</p>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- TECHNOLOGY AREAS -->
		<section class="section-padding relative overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/90 via-(--background)/56 to-(--background)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow justify-center">Dental SEO Coverage</p>

					<h2
						class="section-title mx-auto normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
					>
						Build a stronger search foundation for your practice.
					</h2>

					<p class="section-description mx-auto">
						Dental SEO should improve how your website performs technically,
						how patients find your services locally, and how your pages convert
						search visitors into inquiries.
					</p>
				</div>

				<div class="mt-12 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
					{
						seoTechnologyAreas.map(({ title, description, icon: Icon }) => (
							<article class="service-card group relative overflow-hidden rounded-4xl p-6 transition hover:-translate-y-1 hover:border-(--primary)">
								<div class="absolute -right-12 -top-12 size-32 rounded-full bg-(--primary)/10 blur-2xl transition group-hover:bg-(--primary)/20" />

								<Icon class="relative size-9 text-(--primary)" />

								<h3 class="relative mt-5 text-lg font-black">{title}</h3>

								<p class="relative mt-3 text-sm leading-7 text-(--muted-foreground)">
									{description}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<!-- WHY NEED SEO -->
		<section
			class="relative overflow-hidden bg-site py-20 lg:py-28 xl:py-32"
			style="
				background-image: url('/images/dental-seo-service/dental-seo-service-background.webp');
				background-size: cover;
				background-position: center center;
				background-repeat: no-repeat;
				background-attachment: fixed;
			"
		>
			<div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
				<div class="absolute inset-0 bg-(--background)/70 dark:bg-black/82">
				</div>

				<div
					class="absolute inset-0 bg-linear-to-br from-(--background)/95 via-(--background)/76 to-(--background)/92 dark:from-black/94 dark:via-black/74 dark:to-black/92"
				>
				</div>

				<div
					class="diffuse-sphere absolute -left-44 top-20 h-120 w-120 rounded-full bg-(--primary)/20 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.06)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-85"
					aria-hidden="true"
				>
				</div>
			</div>

			<div class="site-container relative z-10">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow justify-center">
						Why Does Your Dental Practice Need SEO Optimization?
					</p>

					<h2
						class="section-title mx-auto normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
					>
						Search visibility can become a long-term patient acquisition channel.
					</h2>

					<p class="section-description mx-auto">
						When your practice ranks for the right local services, more
						prospective patients can find you, compare your expertise, and take
						the next step toward booking.
					</p>
				</div>

				<div class="mt-12 grid gap-5 sm:grid-cols-2 xl:grid-cols-5">
					{
						seoNeeds.map(({ title, description, icon: Icon }) => (
							<article class="glass-panel glass-highlight rounded-4xl p-6 text-left">
								<div class="relative">
									<Icon class="size-9 text-(--primary)" />

									<h3 class="mt-5 text-lg font-black">{title}</h3>

									<p class="mt-3 text-sm leading-7 text-(--muted-foreground)">
										{description}
									</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<!-- TOOLS / CONVERSION -->
		<section class="section-padding relative overflow-hidden bg-surface">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-52 top-10 h-128 w-lg rounded-full bg-(--primary)/12 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/90 via-(--surface)/58 to-(--surface)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
					<div>
						<p class="section-eyebrow">SEO Technology Partners</p>

						<h2
							class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
						>
							Use the right tools to improve the right signals.
						</h2>

						<p class="section-description">
							Dental IT uses SEO, performance, content, and reporting tools to
							review your website, identify opportunities, improve technical
							health, and support long-term organic growth.
						</p>

						<div class="mt-8 grid gap-3">
							{
								partnerTools.map((item) => (
									<div class="flex items-start gap-3">
										<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
										<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
											{item}
										</p>
									</div>
								))
							}
						</div>
					</div>

					<div class="glass-panel glass-highlight rounded-4xl p-6 sm:p-8 lg:p-10">
						<div class="relative">
							<ShieldCheck class="size-10 text-(--primary)" />

							<h3 class="mt-6 text-2xl font-black tracking-tighter sm:text-3xl">
								Build SEO that supports real appointment opportunities.
							</h3>

							<p class="mt-5 text-base leading-8 text-(--muted-foreground)">
								Ranking is only part of the goal. Your SEO strategy should
								also help patients understand your services, trust your
								practice, and take action.
							</p>


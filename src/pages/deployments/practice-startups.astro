---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import { ArrowRight, CheckCircle2, Building2 } from "lucide-astro";

import {
	heroHighlights,
	startupServices,
	whyStartupNeeds,
	dentalTechnologyAreas,
	launchPlanningItems,
} from "../../data/practice-startups";
---

<MainLayout
	title="Practice Startup IT Services for Dental Practices in Miami, FL"
	description="Dental IT provides practice startup IT services for new dental offices in Miami and South Florida, including infrastructure planning, hardware and software procurement, dental software deployment, network setup, cybersecurity, cloud integration, HIPAA-conscious planning, staff onboarding, and go-live support."
	image="/images/og/dental-it-miami-home-og.webp"
>
	<main class="overflow-hidden">
		<!-- HERO -->
		<section class="relative isolate overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-52 top-16 h-136 w-136 rounded-full bg-(--primary)/18 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-152 w-152 rounded-full bg-(--primary)/14 blur-[170px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.08)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-30"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute top-40 w-full max-w-none blur"
					data-parallax-speed="-0.015"
					data-scroll-opacity-start="0.45"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float absolute bottom-4 w-full max-w-none -translate-x-1/2"
					data-parallax-speed="0.025"
					data-scroll-opacity-start="0.45"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float-soft network-float-delay absolute top-10 w-full max-w-none blur"
					data-parallax-speed="-0.018"
					data-scroll-opacity-start="0.12"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/92 via-(--background)/55 to-(--background)/94"
				>
				</div>
			</div>

			<div
				class="site-container grid min-h-[calc(100vh-5rem)] items-center gap-12 py-16 md:py-20 lg:grid-cols-[1.02fr_0.98fr] lg:py-24"
			>
				<div class="relative z-10">
					<div
						class="glass-panel inline-flex max-w-full items-center gap-3 rounded-full px-4 py-2"
					>
						<span
							class="inline-flex size-2.5 shrink-0 rounded-full bg-(--primary) shadow-[0_0_18px_rgba(239,35,49,0.95)]"
						></span>

						<span
							class="text-xs font-black uppercase tracking-[0.18em] text-(--foreground) sm:tracking-[0.22em]"
						>
							Deployments / Practice Startups
						</span>
					</div>

					<h1
						class="mt-7 max-w-5xl text-balance text-[clamp(2.4rem,5.8vw,5rem)] font-black leading-[0.95] tracking-tighter"
					>
						Launch-ready IT infrastructure for new dental practices.
					</h1>

					<p
						class="mt-7 max-w-2xl text-base leading-8 text-(--muted-foreground) sm:text-lg md:text-xl"
					>
						Lay the foundation for long-term success with Dental IT’s practice
						startup services. From initial planning to go-live support, we help
						your new dental clinic open with secure, reliable, scalable, and
						well-documented technology.
					</p>

					<div class="mt-9 flex flex-col gap-4 sm:flex-row">
						<a
							href="/contact"
							class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
						>
							Get Free Consultation
							<ArrowRight class="size-4" />
						</a>

						<a
							href="#startup-services"
							class="glass-panel inline-flex items-center justify-center gap-2 rounded-full px-7 py-4 text-sm font-black uppercase tracking-wide text-(--foreground) transition hover:-translate-y-1 hover:border-(--primary) hover:text-(--primary)"
						>
							Explore Startup Services
							<ArrowRight class="size-4" />
						</a>
					</div>

					<div class="mt-10 grid gap-3 sm:grid-cols-2">
						{
							heroHighlights.map((item) => (
								<div class="flex items-start gap-3">
									<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
									<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
										{item}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<div
					class="relative mx-auto hidden w-full max-w-xl lg:block lg:max-w-none"
				>
					<div
						class="grid gap-5 sm:grid-cols-2 lg:block lg:min-h-136 xl:min-h-152"
					>
						<div
							class="parallax-layer floating-card lg:absolute lg:left-0 lg:-top-15 lg:w-[80%]"
							data-parallax-speed="0.04"
						>
							<div class="glass-panel rounded-4xl p-3">
								<Image
									src="/images/practice-startups/practice-startups-hero-1.webp"
									alt="Technology planning for a new dental practice startup"
									width={900}
									height={1125}
									format="webp"
									quality="high"
									class="aspect-4/5 w-full rounded-3xl object-cover"
									loading="eager"
									decoding="async"
								/>
							</div>
						</div>

						<div
							class="parallax-layer floating-card-alt lg:absolute lg:-bottom-15 lg:-right-30 lg:w-[80%]"
							data-parallax-speed="-0.035"
						>
							<div class="glass-panel rounded-4xl p-3">
								<Image
									src="/images/practice-startups/practice-startups-hero-2.webp"
									alt="New dental office IT infrastructure setup"
									width={900}
									height={1125}
									format="webp"
									quality="high"
									class="aspect-4/5 w-full rounded-3xl object-cover"
									loading="eager"
									decoding="async"
								/>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- WHO WE ARE / INTRO -->
		<section class="section-padding relative overflow-hidden bg-surface">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="absolute inset-0 bg-linear-to-br from-(--surface)/78 via-(--surface)/45 to-(--surface)/72 dark:from-black/78 dark:via-black/48 dark:to-black/82"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere absolute -left-48 top-10 h-112 w-md rounded-full bg-(--primary)/12 blur-[145px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-136 w-136 rounded-full bg-(--primary)/14 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.06)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-85"
					aria-hidden="true"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute left-1/2 top-12 w-432 max-w-none -translate-x-1/2 blur-2xl"
					data-parallax-speed="-0.012"
					data-scroll-opacity-start="0.03"
					data-scroll-opacity-end="0.12"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-260"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float-soft network-float-delay absolute -right-40 bottom-8 w-240 max-w-none blur-xl"
					data-parallax-speed="-0.016"
					data-scroll-opacity-start="0.04"
					data-scroll-opacity-end="0.18"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/90 via-(--surface)/50 to-(--surface)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
					<div>
						<p class="section-eyebrow">Build the Right Foundation</p>

						<h2
							class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
						>
							Open your practice with technology that is planned, documented,
							and ready to grow.
						</h2>

						<p class="section-description">
							A new dental practice has many moving parts: floor plans,
							operatories, front desk workflows, imaging systems, internet,
							phones, software, cybersecurity, backups, and compliance planning.
							Dental IT helps bring those pieces together before they become
							opening-day problems.
						</p>

						<div class="mt-8 grid gap-3">
							{
								launchPlanningItems.map((item) => (
									<div class="flex items-start gap-3">
										<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
										<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
											{item}
										</p>
									</div>
								))
							}
						</div>
					</div>

					<div
						class="glass-panel glass-highlight rounded-4xl p-6 sm:p-8 lg:p-10"
					>
						<div class="relative">
							<Building2 class="size-10 text-(--primary)" />

							<h3 class="mt-6 text-2xl font-black tracking-tighter sm:text-3xl">
								A smoother startup begins before the first patient appointment.
							</h3>

							<p class="mt-5 text-base leading-8 text-(--muted-foreground)">
								We help coordinate the technology backbone of your new practice
								so your team can walk into a connected, secure, and usable
								environment instead of discovering technical gaps after launch.
							</p>

							<div class="mt-7 grid gap-4 sm:grid-cols-2">
								<div
									class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl"
								>
									<p
										class="text-3xl font-black tracking-tighter text-(--primary)"
									>
										Day 1
									</p>
									<p
										class="mt-2 text-sm font-bold leading-6 text-(--muted-foreground)"
									>
										Technology readiness for opening week.
									</p>
								</div>

								<div
									class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl"
								>
									<p
										class="text-3xl font-black tracking-tighter text-(--primary)"
									>
										A-Z
									</p>
									<p
										class="mt-2 text-sm font-bold leading-6 text-(--muted-foreground)"
									>
										Planning, setup, deployment, and support.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- STARTUP SERVICES -->
		<section
			id="startup-services"
			class="section-padding relative overflow-hidden"
		>
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-44 top-10 h-120 w-120 rounded-full bg-(--primary)/16 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-48 top-[20%] h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute left-1/2 top-0 h-112 w-md -translate-x-1/2 rounded-full bg-(--primary)/10 blur-[130px]"
				>
				</div>

				<div
					class="parallax-layer absolute w-full max-w-none blur"
					data-parallax-speed="-0.012"
					data-scroll-opacity-start="0.02"
					data-scroll-opacity-end="0.1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float absolute left-1/2 top-52 w-432 max-w-none -translate-x-1/2"
					data-parallax-speed="0.018"
					data-scroll-opacity-start="0.08"
					data-scroll-opacity-end="0.28"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float-soft network-float-delay absolute -right-32 top-112 w-232 max-w-none"
					data-parallax-speed="-0.016"
					data-scroll-opacity-start="0.04"
					data-scroll-opacity-end="0.2"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/90 via-(--background)/58 to-(--background)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow justify-center">
						What Our Practice Startup Services Include
					</p>

					<h2
						class="section-title mx-auto normal-case text-[clamp(2rem,4.2vw,3.8rem)] leading-none"
					>
						Complete IT planning for your new dental clinic.
					</h2>

					<p class="section-description mx-auto">
						From network design and procurement to software deployment,
						compliance planning, training, and go-live support, we help your
						startup avoid preventable technology problems.
					</p>
				</div>

				<div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
					{
						startupServices.map(({ title, description, icon: Icon }) => (
							<article class="service-card group relative overflow-hidden rounded-4xl p-6 transition hover:-translate-y-1 hover:border-(--primary) md:p-7">
								<div class="absolute -right-12 -top-12 size-32 rounded-full bg-(--primary)/10 blur-2xl transition group-hover:bg-(--primary)/20" />

								<Icon class="relative size-10 text-(--primary)" />

								<h3 class="relative mt-6 text-lg font-black sm:text-xl">
									{title}
								</h3>

								<p class="relative mt-4 text-sm leading-7 text-(--muted-foreground)">
									{description}
								</p>
							</article>
						))
					}
				</div>

				<div class="mt-12 flex justify-center">
					<a
						href="/contact"
						class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
					>
						Get a Free Quote
						<ArrowRight class="size-4" />
					</a>
				</div>
			</div>
		</section>

		<!-- WHY CHOOSE / READY TO BUILD -->
		<section
			class="section-padding relative overflow-hidden bg-surface"
			style="
				background-image: url('/images/practice-startups/practice-startups-background.webp');
				background-size: cover;
				background-position: center center;
				background-repeat: no-repeat;
				background-attachment: fixed;
			"
		>
			<div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
				<div
					class="absolute inset-0 bg-linear-to-br from-(--surface)/86 via-(--surface)/95 to-(--surface)/90 dark:from-black/90 dark:via-black/84 dark:to-black/94"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere absolute -left-52 top-10 h-128 w-lg rounded-full bg-(--primary)/14 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.06)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-85"
					aria-hidden="true"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute left-1/2 top-24 w-512 max-w-none -translate-x-1/2 blur-2xl"
					data-parallax-speed="-0.015"
					data-scroll-opacity-start="0.03"
					data-scroll-opacity-end="0.14"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float absolute left-1/2 bottom-8 w-416 max-w-none -translate-x-1/2 blur-3xl"
					data-parallax-speed="0.018"
					data-scroll-opacity-start="0.06"
					data-scroll-opacity-end="0.22"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-260"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float-soft network-float-delay absolute -right-32 top-32 w-216 max-w-none blur-3xl"
					data-parallax-speed="-0.016"
					data-scroll-opacity-start="0.04"
					data-scroll-opacity-end="0.16"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/90 via-(--surface)/55 to-(--surface)/94"
					aria-hidden="true"
				>
				</div>
			</div>

			<div class="site-container relative z-10">
				<div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
					<div class="lg:sticky lg:top-32">
						<p class="section-eyebrow">Ready to Build Your Dream Practice?</p>

						<h2
							class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
						>
							Avoid tech stress when launching your new practice.
						</h2>

						<p class="section-description">
							Opening a dental practice is already a major project. Your
							technology should not become the source of delays, confusion, or
							last-minute decisions. Dental IT helps you plan and deploy a
							startup environment that supports opening day and long-term
							growth.
						</p>

						<div class="mt-8">
							<a
								href="/contact"
								class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
							>
								Schedule Startup Consultation
								<ArrowRight class="size-4" />
							</a>
						</div>
					</div>

					<div class="grid gap-5 md:grid-cols-2">
						{
							whyStartupNeeds.map(
								({ title, description, icon: Icon }, index) => (
									<article
										class:list={[
											"glass-panel glass-highlight rounded-4xl p-6 md:p-7",
											index === whyStartupNeeds.length - 1 && "md:col-span-2",
										]}
									>
										<div class="relative">
											<div class="flex size-12 items-center justify-center rounded-2xl bg-(--primary) text-white">
												<Icon class="size-6" />
											</div>

											<h3 class="mt-6 text-lg font-black uppercase tracking-tight sm:text-xl">
												{title}
											</h3>

											<p class="mt-4 text-sm leading-7 text-(--muted-foreground)">
												{description}
											</p>
										</div>
									</article>
								),
							)
						}
					</div>
				</div>
			</div>
		</section>

		<!-- TECHNOLOGIES -->
		<section class="section-padding relative overflow-hidden">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-44 top-10 h-120 w-120 rounded-full bg-(--primary)/14 blur-[150px]"

---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import {
	ArrowRight,
	CheckCircle2,
	ChevronLeft,
	ChevronRight,
	LayoutDashboard,
	ShieldCheck,
	SearchCheck,
} from "lucide-astro";

import {
	heroHighlights,
	includedServices,
	whyChooseTechAssessment,
	assessmentNeeds,
	technologyAreas,
	complianceItems,
	clarityItems,
	consultationItems,
	process,
} from "../../data/tech-assessment";
---

<MainLayout
	title="Tech Assessment for Dental Practices in Miami, FL"
	description="Dental IT provides tech assessment services for dental practices in Miami and South Florida, including infrastructure audits, performance benchmarking, security and compliance reviews, workflow analysis, scalability forecasting, and actionable recommendations."
	image="/images/og/dental-it-miami-home-og.webp"
>
	<main class="overflow-hidden">
		<!-- HERO -->
		<section class="relative isolate overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-52 top-16 h-136 w-136 rounded-full bg-(--primary)/18 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-152 w-152 rounded-full bg-(--primary)/14 blur-[170px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.08)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-30"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute top-40 w-full max-w-none blur"
					data-parallax-speed="-0.015"
					data-scroll-opacity-start="0.45"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float absolute bottom-4 w-full max-w-none -translate-x-1/2"
					data-parallax-speed="0.025"
					data-scroll-opacity-start="0.45"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float-soft network-float-delay absolute top-10 w-full max-w-none blur"
					data-parallax-speed="-0.018"
					data-scroll-opacity-start="0.12"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/92 via-(--background)/55 to-(--background)/94"
				>
				</div>
			</div>

			<div
				class="site-container grid min-h-[calc(100vh-5rem)] items-center gap-12 py-16 md:py-20 lg:grid-cols-[1.02fr_0.98fr] lg:py-24"
			>
				<div class="relative z-10">
					<div
						class="glass-panel inline-flex max-w-full items-center gap-3 rounded-full px-4 py-2"
					>
						<span
							class="inline-flex size-2.5 shrink-0 rounded-full bg-(--primary) shadow-[0_0_18px_rgba(239,35,49,0.95)]"
						></span>

						<span
							class="text-xs font-black uppercase tracking-[0.18em] text-(--foreground) sm:tracking-[0.22em]"
						>
							Deployments / Tech Assessment
						</span>
					</div>

					<h1
						class="mt-7 max-w-5xl text-balance text-[clamp(2.4rem,5.8vw,5rem)] font-black leading-[0.95] tracking-tighter"
					>
						Tech assessment for dental practices.
					</h1>

					<p
						class="mt-7 max-w-2xl text-base leading-8 text-(--muted-foreground) sm:text-lg md:text-xl"
					>
						Dental IT helps dental practices understand the strengths,
						weaknesses, risks, and opportunities inside their IT environment
						through infrastructure audits, performance benchmarking, security
						reviews, workflow analysis, and actionable recommendations.
					</p>

					<div class="mt-9 flex flex-col gap-4 sm:flex-row">
						<a
							href="/contact"
							class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
						>
							Get Free Assessment
							<ArrowRight class="size-4" />
						</a>

						<a
							href="#included"
							class="glass-panel inline-flex items-center justify-center gap-2 rounded-full px-7 py-4 text-sm font-black uppercase tracking-wide text-(--foreground) transition hover:-translate-y-1 hover:border-(--primary) hover:text-(--primary)"
						>
							Explore Assessments
							<ArrowRight class="size-4" />
						</a>
					</div>

					<div class="mt-10 grid gap-3 sm:grid-cols-2">
						{
							heroHighlights.map((item) => (
								<div class="flex items-start gap-3">
									<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
									<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
										{item}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<div class="relative mx-auto hidden w-full max-w-xl lg:block lg:max-w-none">
					<div
						class="grid gap-5 sm:grid-cols-2 lg:block lg:min-h-136 xl:min-h-152"
					>
						<div
							class="parallax-layer floating-card lg:absolute lg:left-0 lg:-top-15 lg:w-[80%]"
							data-parallax-speed="0.04"
						>
							<div class="glass-panel rounded-4xl p-3">
								<Image
									src="/images/tech-assessment/tech-assessment-hero-1.webp"
									alt="Technology assessment dashboard for a dental practice"
									width={900}
									height={1125}
									format="webp"
									quality="high"
									class="aspect-4/5 w-full rounded-3xl object-cover"
									loading="eager"
									decoding="async"
								/>
							</div>
						</div>

						<div
							class="parallax-layer floating-card-alt lg:absolute lg:-bottom-15 lg:-right-30 lg:w-[80%]"
							data-parallax-speed="-0.035"
						>
							<div class="glass-panel rounded-4xl p-3">
								<Image
									src="/images/tech-assessment/tech-assessment-hero-2.webp"
									alt="Dental practice IT audit and infrastructure review"
									width={900}
									height={1125}
									format="webp"
									quality="high"
									class="aspect-4/5 w-full rounded-3xl object-cover"
									loading="eager"
									decoding="async"
								/>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- PROCESS -->
		<section class="section-padding relative overflow-hidden bg-(--surface)/40">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-52 top-10 h-128 w-lg rounded-full bg-(--primary)/14 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute left-1/2 top-96 w-512 max-w-none -translate-x-1/2 blur-sm"
					data-parallax-speed="-0.015"
					data-scroll-opacity-start="0.03"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-512 min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float absolute left-1/2 bottom-8 w-416 max-w-none -translate-x-1/2 blur-3xl"
					data-parallax-speed="0.018"
					data-scroll-opacity-start="0.06"
					data-scroll-opacity-end="0.2"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={4096}
						height={620}
						class="w-full min-w-260"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float-soft network-float-delay absolute -right-32 top-32 w-216 max-w-none blur-3xl"
					data-parallax-speed="-0.016"
					data-scroll-opacity-start="0.04"
					data-scroll-opacity-end="0.16"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/88 via-(--surface)/48 to-(--surface)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow justify-center">
						Our Assessment Process
					</p>

					<h2
						class="section-title mx-auto normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
					>
						From technology review to a clear action plan.
					</h2>

					<p class="section-description mx-auto">
						A structured process to help your dental practice understand risks,
						performance issues, security gaps, infrastructure needs, and the next
						steps that matter most.
					</p>
				</div>

				<div
					id="process-carousel"
					class="relative mt-12"
					data-current-slide="0"
				>
					<div class="overflow-hidden rounded-4xl">
						<div
							class="process-track flex transition-transform duration-500 ease-out"
							data-process-track
						>
							{
								process.map((item) => (
									<div class="w-full shrink-0 px-2" data-process-slide>
										<article class="group relative overflow-hidden rounded-4xl border border-white/20 bg-white/6 p-3 backdrop-blur-2xl lg:rounded-[2.5rem]">
											<div class="pointer-events-none absolute inset-0 rounded-[inherit] bg-linear-to-br from-white/18 via-black/4 to-(--primary)/10" />

											<div class="pointer-events-none absolute left-6 top-6 h-24 w-24 rounded-full border border-white/25 opacity-60" />

											<div class="pointer-events-none absolute right-8 top-8 h-px w-32 bg-linear-to-r from-transparent via-(--primary) to-transparent opacity-70" />

											<div class="pointer-events-none absolute bottom-0 right-0 h-44 w-64 bg-[radial-gradient(circle_at_center,rgba(239,35,49,0.18)_1px,transparent_1.5px)] bg-size-[14px_14px] opacity-70" />

											<div class="relative grid overflow-hidden rounded-[1.6rem] lg:grid-cols-[1.1fr_0.9fr]">
												<div class="relative min-h-80 overflow-hidden lg:min-h-[30rem]">
													<Image
														src={item.image}
														alt={item.alt}
														width={1200}
														height={900}
														format="webp"
														quality="high"
														class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
														loading="lazy"
														decoding="async"
													/>

													<div class="absolute inset-0 bg-linear-to-br from-white/10 via-black/10 to-(--primary)/25" />
													<div class="absolute inset-0 bg-linear-to-t from-black/65 via-black/20 to-white/20" />

													<div class="pointer-events-none absolute -left-16 top-12 h-80 w-80 rounded-full border border-(--primary)/45 opacity-70 shadow-[0_0_80px_rgba(239,35,49,0.35)]" />

													<div class="pointer-events-none absolute inset-5 rounded-[1.25rem] border border-white/20" />
												</div>

												<div class="relative flex min-h-80 flex-col justify-center bg-(--card) p-8 backdrop-blur-xl dark:bg-black/70 md:p-10 lg:min-h-[30rem] lg:p-12">
													<div class="pointer-events-none absolute left-0 top-1/2 h-20 w-px -translate-y-1/2 bg-linear-to-b from-transparent via-(--primary) to-transparent" />

													<p class="text-xs font-black uppercase tracking-[0.32em] text-(--primary)">
														How We Work
													</p>

													<h3 class="mt-5 text-[clamp(2.4rem,6vw,4.5rem)] font-black leading-none tracking-tighter text-(--foreground)">
														{item.title}
													</h3>

													<div class="mt-5 h-px w-32 bg-linear-to-r from-(--primary) via-(--primary)/60 to-transparent" />

													<p class="mt-8 max-w-md text-base leading-8 text-(--muted-foreground) md:text-lg">
														{item.description}
													</p>
												</div>
											</div>
										</article>
									</div>
								))
							}
						</div>
					</div>

					<div class="mt-8 flex items-center justify-center gap-4">
						<button
							type="button"
							class="process-prev inline-flex size-12 items-center justify-center rounded-full border border-(--border) bg-(--card) text-(--foreground) shadow-soft transition hover:border-(--primary) hover:bg-(--primary) hover:text-white"
							aria-label="Previous process step"
						>
							<ChevronLeft class="size-5" />
						</button>

						<div class="flex items-center gap-2" aria-hidden="true">
							{
								process.map((_, index) => (
									<span
										class:list={[
											"process-dot size-2 rounded-full bg-(--muted)/40 transition-all duration-300",
											index === 0 && "is-active",
										]}
										data-process-dot
									/>
								))
							}
						</div>

						<button
							type="button"
							class="process-next inline-flex size-12 items-center justify-center rounded-full border border-(--border) bg-(--card) text-(--foreground) shadow-soft transition hover:border-(--primary) hover:bg-(--primary) hover:text-white"
							aria-label="Next process step"
						>
							<ChevronRight class="size-5" />
						</button>
					</div>
				</div>
			</div>
		</section>

		<!-- INTRO -->
		<section class="section-padding relative overflow-hidden bg-surface">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="absolute inset-0 bg-linear-to-br from-(--surface)/78 via-(--surface)/45 to-(--surface)/72 dark:from-black/78 dark:via-black/48 dark:to-black/82"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere absolute -left-48 top-10 h-112 w-md rounded-full bg-(--primary)/12 blur-[145px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-136 w-136 rounded-full bg-(--primary)/14 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.06)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-85"
					aria-hidden="true"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute left-1/2 top-12 w-432 max-w-none -translate-x-1/2 blur-2xl"
					data-parallax-speed="-0.012"
					data-scroll-opacity-start="0.03"
					data-scroll-opacity-end="0.12"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-260"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float-soft network-float-delay absolute -right-40 bottom-8 w-240 max-w-none blur-xl"
					data-parallax-speed="-0.016"
					data-scroll-opacity-start="0.04"
					data-scroll-opacity-end="0.18"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/90 via-(--surface)/50 to-(--surface)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
					<div>
						<p class="section-eyebrow">
							Comprehensive Technology Audits
						</p>

						<h2
							class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
						>
							Gain clarity on your IT environment before problems become costly.
						</h2>

						<p class="section-description">
							A tech assessment gives your practice a clearer view of system
							performance, infrastructure health, cybersecurity risks,
							compliance gaps, software concerns, and future technology needs.
							Instead of guessing what should be upgraded next, you get a
							practical roadmap.
						</p>

						<div class="mt-8 grid gap-3">
							{
								consultationItems.map((item) => (
									<div class="flex items-start gap-3">
										<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
										<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
											{item}
										</p>
									</div>
								))
							}
						</div>
					</div>

					<div class="glass-panel glass-highlight rounded-4xl p-6 sm:p-8 lg:p-10">
						<div class="relative">
							<SearchCheck class="size-10 text-(--primary)" />

							<h3 class="mt-6 text-2xl font-black tracking-tighter sm:text-3xl">
								Insights your practice can actually act on.
							</h3>

							<p class="mt-5 text-base leading-8 text-(--muted-foreground)">
								Dental IT reviews your systems through the lens of daily dental
								operations: front desk performance, clinical workflows, imaging,
								network reliability, backups, cybersecurity, and patient data
								protection.
							</p>

							<div class="mt-7 grid gap-4 sm:grid-cols-2">
								<div class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl">
									<p class="text-3xl font-black tracking-tighter text-(--primary)">
										Audit
									</p>
									<p class="mt-2 text-sm font-bold leading-6 text-(--muted-foreground)">
										Inventory assets, systems, licenses, and network dependencies.
									</p>
								</div>

								<div class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl">
									<p class="text-3xl font-black tracking-tighter text-(--primary)">
										Plan
									</p>
									<p class="mt-2 text-sm font-bold leading-6 text-(--muted-foreground)">
										Prioritize fixes, improvements, and future upgrades.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INCLUDED SERVICES -->
		<section
			id="included"
			class="section-padding relative overflow-hidden"
		>
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-44 top-10 h-120 w-120 rounded-full bg-(--primary)/16 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-48 top-[20%] h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute left-1/2 top-0 h-112 w-md -translate-x-1/2 rounded-full bg-(--primary)/10 blur-[130px]"
				>
				</div>

				<div
					class="parallax-layer absolute w-full max-w-none blur"
					data-parallax-speed="-0.012"
					data-scroll-opacity-start="0.02"
					data-scroll-opacity-end="0.1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float absolute left-1/2 top-52 w-432 max-w-none -translate-x-1/2"
					data-parallax-speed="0.018"
					data-scroll-opacity-start="0.08"
					data-scroll-opacity-end="0.28"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float-soft network-float-delay absolute -right-32 top-112 w-232 max-w-none"
					data-parallax-speed="-0.016"
					data-scroll-opacity-start="0.04"
					data-scroll-opacity-end="0.2"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/90 via-(--background)/58 to-(--background)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow justify-center">
						What Our Tech Assessments Include

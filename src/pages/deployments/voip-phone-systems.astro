  <style>
    @keyframes floatY {
      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-14px);
      }
    }

    @keyframes networkFloat {
      0%,
      100% {
        translate: 0 0;
      }

      50% {
        translate: 0 -22px;
      }
    }

    @keyframes networkFloatSoft {
      0%,
      100% {
        translate: 0 0;
        opacity: 0.16;
      }

      50% {
        translate: 0 -18px;
        opacity: 0.28;
      }
    }

    @keyframes diffusePulse {
      0%,
      100% {
        transform: scale(1);
        opacity: 0.75;
      }

      50% {
        transform: scale(1.08);
        opacity: 1;
      }
    }

    .floating-card {
      animation: floatY 6s ease-in-out infinite;
    }

    .floating-card-alt {
      animation: floatY 7s ease-in-out infinite;
      animation-delay: -2.5s;
    }

    .network-float {
      animation: networkFloat 9s ease-in-out infinite;
      will-change: translate, transform;
    }

    .network-float-soft {
      animation: networkFloatSoft 11s ease-in-out infinite;
      will-change: translate, opacity, transform;
    }

    .network-float-delay {
      animation-delay: -4s;
    }

    .network-scroll-opacity {
      opacity: var(--network-scroll-opacity, 1);
      transition: opacity 1500ms linear;
      will-change: opacity, transform;
    }

    .diffuse-sphere {
      animation: diffusePulse 10s ease-in-out infinite;
      will-change: transform, opacity;
    }

    .diffuse-sphere-delay {
      animation-delay: -5s;
    }

    @media (max-width: 1279px) {
      .floating-card,
      .floating-card-alt {
        animation: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .floating-card,
      .floating-card-alt,
      .network-float,
      .network-float-soft,
      .diffuse-sphere {
        animation: none;
      }

      .network-scroll-opacity {
        transition: none;
      }
    }
  </style>

  <script>
    const parallaxLayers = document.querySelectorAll("[data-parallax-speed]");
    const scrollOpacityLayers = document.querySelectorAll(".network-scroll-opacity");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

    const updateScrollOpacity = () => {
      const scrollY = window.scrollY;
      const viewportHeight = window.innerHeight || 1;

      scrollOpacityLayers.forEach((layer) => {
        const startOpacity = Number(
          layer.getAttribute("data-scroll-opacity-start") || 0.08,
        );
        const endOpacity = Number(
          layer.getAttribute("data-scroll-opacity-end") || 0.45,
        );

        const fadeDistance = viewportHeight * 0.85;
        const progress = clamp(scrollY / fadeDistance, 0, 1);
        const opacity = startOpacity + (endOpacity - startOpacity) * progress;

        layer.style.setProperty("--network-scroll-opacity", String(opacity));
      });
    };

    const updateParallax = () => {
      updateScrollOpacity();

      if (reduceMotion.matches || window.innerWidth < 1024) return;

      const scrollY = window.scrollY;

      parallaxLayers.forEach((layer) => {
        const speed = Number(layer.getAttribute("data-parallax-speed") || 0);
        const y = scrollY * speed;

        layer.style.setProperty("--parallax-y", `${y}px`);
        layer.style.transform = `translate3d(0, var(--parallax-y), 0)`;
      });
    };

    const resetParallax = () => {
      parallaxLayers.forEach((layer) => {
        layer.style.removeProperty("--parallax-y");
        layer.style.transform = "";
      });
    };

    const handleParallax = () => {
      updateScrollOpacity();

      if (reduceMotion.matches || window.innerWidth < 1024) {
        resetParallax();
        return;
      }

      updateParallax();
    };

    handleParallax();

    window.addEventListener("scroll", handleParallax, { passive: true });
    window.addEventListener("resize", handleParallax);
  </script>

	<style>
		@keyframes floatY {
			0%,
			100% {
				transform: translateY(0);
			}

			50% {
				transform: translateY(-14px);
			}
		}

		@keyframes networkFloat {
			0%,
			100% {
				translate: 0 0;
			}

			50% {
				translate: 0 -22px;
			}
		}

		@keyframes networkFloatSoft {
			0%,
			100% {
				translate: 0 0;
				opacity: 0.16;
			}

			50% {
				translate: 0 -18px;
				opacity: 0.28;
			}
		}

		@keyframes diffusePulse {
			0%,
			100% {
				transform: scale(1);
				opacity: 0.75;
			}

			50% {
				transform: scale(1.08);
				opacity: 1;
			}
		}

		@keyframes heroKenBurns {
			0% {
				transform: scale(1.04) translate3d(0, 0, 0);
			}

			100% {
				transform: scale(1.12) translate3d(-1.5%, -1.5%, 0);
			}
		}

		.floating-card {
			animation: floatY 6s ease-in-out infinite;
		}

		.floating-card-delay {
			animation-delay: -2.5s;
		}

		.network-float {
			animation: networkFloat 9s ease-in-out infinite;
			will-change: translate, transform;
		}

		.network-float-soft {
			animation: networkFloatSoft 11s ease-in-out infinite;
			will-change: translate, opacity, transform;
		}

		.network-float-delay {
			animation-delay: -4s;
		}

		.diffuse-sphere {
			animation: diffusePulse 10s ease-in-out infinite;
			will-change: transform, opacity;
		}

		.diffuse-sphere-delay {
			animation-delay: -5s;
		}

		.hero-slide {
			transform: scale(1.04);
		}

		.hero-slide.is-active {
			opacity: 1;
			animation: heroKenBurns 5s ease-out forwards;
		}

		.hero-slide-dot.is-active {
			width: 1.5rem;
			background: var(--primary);
		}

		@media (max-width: 1279px) {
			.floating-card {
				animation: none;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.floating-card,
			.network-float,
			.network-float-soft,
			.diffuse-sphere,
			.hero-slide.is-active {
				animation: none;
			}

			.hero-slide.is-active {
				transform: scale(1);
			}
		}
	</style>

	<script>
		const parallaxLayers = document.querySelectorAll("[data-parallax-speed]");
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

		const updateParallax = () => {
			if (reduceMotion.matches || window.innerWidth < 1024) return;

			const scrollY = window.scrollY;

			parallaxLayers.forEach((layer) => {
				const speed = Number(layer.getAttribute("data-parallax-speed") || 0);
				const y = scrollY * speed;

				layer.style.setProperty("--parallax-y", `${y}px`);
				layer.style.transform = `translate3d(0, var(--parallax-y), 0)`;
			});
		};

		const resetParallax = () => {
			parallaxLayers.forEach((layer) => {
				layer.style.removeProperty("--parallax-y");
				layer.style.transform = "";
			});
		};

		const handleParallax = () => {
			if (reduceMotion.matches || window.innerWidth < 1024) {
				resetParallax();
				return;
			}

			updateParallax();
		};

		handleParallax();

		window.addEventListener("scroll", handleParallax, { passive: true });
		window.addEventListener("resize", handleParallax);

		const heroSlideshow = document.querySelector("#hero-slideshow");

		if (heroSlideshow) {
			const slides = Array.from(
				heroSlideshow.querySelectorAll("[data-hero-slide]"),
			);
			const dots = Array.from(heroSlideshow.querySelectorAll("[data-hero-dot]"));
			const previousButton = heroSlideshow.querySelector(".hero-slide-prev");
			const nextButton = heroSlideshow.querySelector(".hero-slide-next");

			let currentSlide = 0;
			let slideTimer;

			const activateSlide = (index) => {
				currentSlide = (index + slides.length) % slides.length;

				slides.forEach((slide, slideIndex) => {
					const isActive = slideIndex === currentSlide;

					slide.classList.toggle("is-active", isActive);
					slide.dataset.active = String(isActive);

					if (isActive) {
						slide.style.animation = "none";
						slide.offsetHeight;
						slide.style.animation = "";
					}
				});

				dots.forEach((dot, dotIndex) => {
					dot.classList.toggle("is-active", dotIndex === currentSlide);
				});

				heroSlideshow.dataset.currentSlide = String(currentSlide);
			};

			const goToNextSlide = () => {
				activateSlide(currentSlide + 1);
			};

			const goToPreviousSlide = () => {
				activateSlide(currentSlide - 1);
			};

			const restartSlideTimer = () => {
				window.clearInterval(slideTimer);
				slideTimer = window.setInterval(goToNextSlide, 5000);
			};

			nextButton?.addEventListener("click", () => {
				goToNextSlide();
				restartSlideTimer();
			});

			previousButton?.addEventListener("click", () => {
				goToPreviousSlide();
				restartSlideTimer();
			});

			activateSlide(0);
			restartSlideTimer();
		}
	</script>

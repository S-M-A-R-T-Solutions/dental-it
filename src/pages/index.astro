---
import MainLayout from "../layouts/MainLayout.astro";
import {
	ArrowRight,
	ShieldCheck,
	Activity,
	DatabaseBackup,
	CheckCircle2,
	Sparkles,
	ChevronLeft,
	ChevronRight,
} from "lucide-astro";

import {
	stats,
	techSupportServices,
	deploymentServices,
	practiceSolutions,
	trustItems,
	whyChoose,
	process,
} from "../data/home.ts";

const heroSlides = [
	{
		src: "/images/home/hero-dental-it-dashboard-miami-01.webp",
		alt: "Dental IT services dashboard for a Miami dental practice",
	},
	{
		src: "/images/home/hero-dental-office-monitoring-miami-02.webp",
		alt: "Dental office technology monitoring in Miami",
	},
	{
		src: "/images/home/hero-dental-cybersecurity-miami-03.webp",
		alt: "Dental cybersecurity protection for a Miami dental office",
	},
	{
		src: "/images/home/hero-dental-cloud-backup-miami-04.webp",
		alt: "Cloud backup and recovery planning for a Miami dental practice",
	},
	{
		src: "/images/home/hero-dental-it-support-team-miami-05.webp",
		alt: "Dental IT support team helping a Miami dental practice",
	},
];
---

<MainLayout
	title="Dental IT Services in Miami, FL | Managed IT, Cybersecurity & HIPAA Support"
	description="Dental IT provides managed IT support, cybersecurity, HIPAA consulting, cloud backups, proactive maintenance, deployments, VoIP, web design, and SEO services for dental practices in Miami and South Florida."
	image="/images/og/dental-it-miami-home-og.jpg"
>
	<main class="overflow-hidden">
		<!-- HERO -->
		<section id="hero" class="relative isolate overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-52 top-16 h-136 w-136 rounded-full bg-(--primary)/18 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-152 w-152 rounded-full bg-(--primary)/14 blur-[170px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.08)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-30"
				>
				</div>

				<div
					class="parallax-layer absolute top-40 w-full max-w-none opacity-[0.45] blur"
					data-parallax-speed="-0.015"
					aria-hidden="true"
				>
					<img
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float absolute bottom-4 w-full max-w-none -translate-x-1/2 opacity-[0.45]"
					data-parallax-speed="0.025"
					aria-hidden="true"
				>
					<img
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float-soft network-float-delay absolute top-10 w-full max-w-none opacity-[0.08] blur"
					data-parallax-speed="-0.018"
					aria-hidden="true"
				>
					<img
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						class="w-full"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/92 via-(--background)/50 to-(--background)/92"
				>
				</div>
			</div>

			<div
				class="site-container grid min-h-[calc(100vh-5rem)] items-center gap-12 py-16 md:py-20 lg:grid-cols-[1.02fr_0.98fr] lg:py-24"
			>
				<div class="relative z-10">
					<div
						class="glass-panel inline-flex max-w-full items-center gap-3 rounded-full px-4 py-2"
					>
						<span
							class="inline-flex size-2.5 shrink-0 rounded-full bg-(--primary) shadow-[0_0_18px_rgba(239,35,49,0.95)]"
						></span>

						<span
							class="text-xs font-black uppercase tracking-[0.18em] text-(--foreground) sm:tracking-[0.22em]"
						>
							Dental IT Services in Miami, FL
						</span>
					</div>

					<h1
						class="mt-7 max-w-5xl text-balance text-[clamp(2.35rem,5.5vw,4.75rem)] font-black leading-[0.95] tracking-tighter"
					>
						Reliable IT for dental practices that cannot afford downtime.
					</h1>

					<p
						class="mt-7 max-w-2xl text-base leading-8 text-(--muted-foreground) sm:text-lg md:text-xl"
					>
						Dental IT helps Miami and South Florida dental offices stay secure,
						backed up, compliant, monitored, and supported — so your team can
						focus on patients instead of technology problems.
					</p>

					<div class="mt-9 flex flex-col gap-4 sm:flex-row">
						<a
							href="/contact"
							class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
						>
							Get Free IT Assessment
							<ArrowRight class="size-4" />
						</a>

						<a
							href="#services"
							class="glass-panel inline-flex items-center justify-center gap-2 rounded-full px-7 py-4 text-sm font-black uppercase tracking-wide text-(--foreground) transition hover:-translate-y-1 hover:border-(--primary) hover:text-(--primary)"
						>
							Explore Services
							<ArrowRight class="size-4" />
						</a>
					</div>

					<div class="mt-10 grid gap-3 sm:grid-cols-2">
						{
							trustItems.slice(0, 4).map((item) => (
								<div class="flex items-start gap-3">
									<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
									<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
										{item}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<div class="relative mx-auto w-full max-w-xl lg:max-w-none">
					<div class="relative">
						<div class="parallax-layer" data-parallax-speed="0.035">
							<div
								id="hero-slideshow"
								class="glass-panel glass-highlight relative overflow-hidden rounded-4xl p-3 sm:rounded-[2.5rem] sm:p-4"
								data-current-slide="0"
							>
								<!-- SEO image recommendation:
									Place these local images in:
									public/images/home/

									Recommended filenames:
									hero-dental-it-dashboard-miami-01.webp
									hero-dental-office-monitoring-miami-02.webp
									hero-dental-cybersecurity-miami-03.webp
									hero-dental-cloud-backup-miami-04.webp
									hero-dental-it-support-team-miami-05.webp
								-->

								<div
									class="relative aspect-[4/4.8] overflow-hidden rounded-3xl sm:rounded-4xl lg:aspect-4/5"
								>
									{
										heroSlides.map((slide, index) => (
											<img
												src={slide.src}
												alt={slide.alt}
												class:list={[
													"hero-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700",
													index === 0 && "is-active",
												]}
												data-hero-slide
												data-active={index === 0 ? "true" : "false"}
												loading={index === 0 ? "eager" : "lazy"}
												decoding="async"
											/>
										))
									}
								</div>

								<button
									type="button"
									class="hero-slide-prev absolute left-6 top-1/2 z-20 inline-flex size-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/15 bg-black/45 text-white shadow-xl backdrop-blur-xl transition hover:bg-(--primary) sm:left-8"
									aria-label="Previous hero image"
								>
									<ChevronLeft class="size-5" />
								</button>

								<button
									type="button"
									class="hero-slide-next absolute right-6 top-1/2 z-20 inline-flex size-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/15 bg-black/45 text-white shadow-xl backdrop-blur-xl transition hover:bg-(--primary) sm:right-8"
									aria-label="Next hero image"
								>
									<ChevronRight class="size-5" />
								</button>

								<div
									class="absolute inset-x-5 bottom-5 z-20 rounded-2xl border border-white/15 bg-black/55 p-4 text-white shadow-2xl backdrop-blur-2xl sm:inset-x-8 sm:bottom-8 sm:rounded-3xl sm:p-5"
								>
									<p
										class="text-xs font-black uppercase tracking-[0.2em] text-(--primary)"
									>
										Live Monitoring
									</p>

									<div class="mt-4 grid grid-cols-3 gap-3">
										<div>
											<p class="text-xl font-black text-white sm:text-2xl">
												24/7
											</p>
											<p class="mt-1 text-[0.7rem] text-white/65 sm:text-xs">
												Monitoring
											</p>
										</div>

										<div>
											<p class="text-xl font-black text-white sm:text-2xl">
												EDR
											</p>
											<p class="mt-1 text-[0.7rem] text-white/65 sm:text-xs">
												Security
											</p>
										</div>

										<div>
											<p class="text-xl font-black text-white sm:text-2xl">
												HIPAA
											</p>
											<p class="mt-1 text-[0.7rem] text-white/65 sm:text-xs">
												Support
											</p>
										</div>
									</div>
								</div>

								<div
									class="absolute bottom-32 left-1/2 z-20 hidden -translate-x-1/2 items-center gap-2 sm:flex"
								>
									{
										heroSlides.map((_, index) => (
											<span
												class:list={[
													"hero-slide-dot size-2 rounded-full bg-white/35 transition-all duration-300",
													index === 0 && "is-active",
												]}
												data-hero-dot
												aria-hidden="true"
											/>
										))
									}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- STATS -->
		<section class="relative border-y border-(--border) bg-surface">
			<div
				class="site-container grid gap-px overflow-hidden py-8 sm:grid-cols-2 lg:grid-cols-4 lg:py-10"
			>
				{
					stats.map((stat) => (
						<div class="group relative row-5 p-5 sm:p-6 lg:p-8">
							<div class="absolute inset-0 rounded-2xl bg-(--primary) opacity-0 transition group-hover:opacity-[0.06]" />
							<p class="relative text-[clamp(2.4rem,5vw,3.25rem)] font-black tracking-tighter text-(--foreground)">
								{stat.prefix}
								<span class="text-(--primary)">{stat.value}</span>
								{stat.suffix}
							</p>
							<p class="relative mt-3 max-w-xs text-sm font-bold leading-6 text-(--muted-foreground)">
								{stat.label}
							</p>
						</div>
					))
				}
			</div>
		</section>

		<!-- INTRO -->
		<section class="section-padding relative overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-48 top-10 h-112 w-md rounded-full bg-(--primary)/12 blur-[145px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-56 bottom-10 h-128 w-lg rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/86 via-(--background)/45 to-(--background)/92"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div
					class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start xl:gap-10"
				>
					<div class="lg:sticky lg:top-32">
						<div class="max-w-4xl text-left">
							<p class="section-eyebrow">
								Custom IT Solutions for Dental Practices
							</p>

							<h2
								class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
							>
								Built for the way dental offices actually work.
							</h2>

							<div
								class="site-card mt-8 rounded-4xl p-6 text-left md:p-8 lg:p-9"
							>
								<h3 class="text-xl font-black sm:text-2xl">
									Dental IT support that understands your environment.
								</h3>

								<p class="mt-4 text-base leading-8">
									Your dental practice depends on technology across every part
									of the day: front desk communication, workstations, imaging,
									servers, backups, cybersecurity, cloud systems, and patient
									data security. Dental IT brings those needs into one
									specialized support strategy.
								</p>
							</div>
						</div>
					</div>

					<div class="grid gap-5 md:grid-cols-2">
						<div class="site-card rounded-4xl p-6 md:p-7">
							<Activity class="size-9 text-(--primary)" />

							<h3 class="mt-5 text-lg font-black sm:text-xl">
								24/7 Software & Hardware Monitoring
							</h3>

							<p class="mt-4 text-sm leading-7">
								Continuous visibility into system health helps detect CPU,
								memory, disk, network, and workstation issues before they become
								operational problems.
							</p>
						</div>

						<div class="site-card rounded-4xl p-6 md:p-7">
							<Sparkles class="size-9 text-(--primary)" />

							<h3 class="mt-5 text-lg font-black sm:text-xl">
								Peace of Mind Starting at $0.99/Day
							</h3>

							<p class="mt-4 text-sm leading-7">
								Proactive maintenance helps keep workstations updated,
								protected, monitored, and performing at the level your team
								needs.
							</p>
						</div>

						<div class="site-card rounded-4xl p-6 md:p-7">
							<ShieldCheck class="size-9 text-(--primary)" />

							<h3 class="mt-5 text-lg font-black sm:text-xl">
								Security-First Dental IT Support
							</h3>

							<p class="mt-4 text-sm leading-7">
								Protect your practice with cybersecurity-focused support
								designed to help reduce risks around workstations, patient data,
								backups, and daily dental technology workflows.
							</p>
						</div>

						<div class="site-card rounded-4xl p-6 md:p-7">
							<DatabaseBackup class="size-9 text-(--primary)" />

							<h3 class="mt-5 text-lg font-black sm:text-xl">
								Cloud Backup & Recovery Planning
							</h3>

							<p class="mt-4 text-sm leading-7">
								Keep patient data, imaging files, and business-critical systems
								protected with backup strategies designed to support fast
								recovery and minimize practice downtime.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- SERVICES -->
		<section id="services" class="section-padding relative overflow-hidden bg-surface">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-44 top-10 h-120 w-120 rounded-full bg-(--primary)/16 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-48 top-[35%] h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute left-1/2 top-0 h-112 w-md -translate-x-1/2 rounded-full bg-(--primary)/10 blur-[130px]"
				>
				</div>

				<div
					class="parallax-layer absolute w-full max-w-none opacity-[0.10] blur"
					data-parallax-speed="-0.012"
					aria-hidden="true"
				>
					<img
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float absolute left-1/2 top-52 w-432 max-w-none -translate-x-1/2 opacity-[0.28]"
					data-parallax-speed="0.018"
					aria-hidden="true"
				>
					<img
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float-soft network-float-delay absolute -right-32 top-112 w-232 max-w-none opacity-[0.20]"
					data-parallax-speed="-0.016"
					aria-hidden="true"
				>
					<img
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						class="w-full"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/88 via-(--surface)/48 to-(--surface)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow">Our Services</p>

					<h2
						class="section-title mx-auto normal-case text-[clamp(2rem,4.2vw,3.8rem)] leading-none"
					>
						We got your practice covered.
					</h2>

					<p class="section-description mx-auto">
						From managed IT support and cybersecurity to practice deployments,
						cloud backups, VoIP, web design, SEO, and custom software, Dental IT
						gives dental practices one expert technology partner.
					</p>
				</div>

				<div class="mt-14 lg:mt-16">
					<div class="mb-7 flex items-center gap-4">
						<div class="h-px flex-1 bg-(--border)"></div>
						<h3
							class="text-center text-xs font-black uppercase tracking-[0.2em] text-(--primary) sm:text-sm sm:tracking-[0.22em]"
						>
							Tech Support
						</h3>
						<div class="h-px flex-1 bg-(--border)"></div>
					</div>

					<div class="flex flex-wrap justify-center gap-5">
						{
							techSupportServices.map(
								({ title, href, description, icon: Icon }) => (
									<a
										href={href}
										class="service-card group relative flex w-full flex-col overflow-hidden rounded-4xl p-6 transition hover:-translate-y-1 hover:border-(--primary) md:w-[calc(50%-0.625rem)] md:p-7 xl:w-[calc(25%-0.9375rem)]"
									>
										<div class="absolute -right-12 -top-12 size-32 rounded-full bg-(--primary)/10 blur-2xl transition group-hover:bg-(--primary)/20" />
										<Icon class="relative size-10 text-(--primary)" />
										<h4 class="relative mt-6 text-lg font-black sm:text-xl">
											{title}
										</h4>
										<p class="relative mt-4 text-sm leading-7">
											{description}
										</p>
										<span class="relative mt-6 inline-flex items-center gap-2 text-sm font-black uppercase tracking-wide text-(--primary)">
											Learn More
											<ArrowRight class="size-4 transition group-hover:translate-x-1" />
										</span>
									</a>
								),
							)
						}
					</div>
				</div>

				<div class="mt-16 lg:mt-20">
					<div class="mb-7 flex items-center gap-4">
						<div class="h-px flex-1 bg-(--border)"></div>
						<h3
							class="text-center text-xs font-black uppercase tracking-[0.2em] text-(--primary) sm:text-sm sm:tracking-[0.22em]"
						>
							Deployments
						</h3>
						<div class="h-px flex-1 bg-(--border)"></div>
					</div>

					<div class="flex flex-wrap justify-center gap-5">
						{
							deploymentServices.map(
								({ title, href, description, icon: Icon }) => (
									<a
										href={href}
										class="service-card group relative flex w-full flex-col overflow-hidden rounded-4xl p-6 transition hover:-translate-y-1 hover:border-(--primary) md:w-[calc(50%-0.625rem)] md:p-7 xl:w-[calc(25%-0.9375rem)]"
									>
										<Icon class="size-10 text-(--primary)" />
										<h4 class="mt-6 text-lg font-black sm:text-xl">
											{title}
										</h4>
										<p class="mt-4 text-sm leading-7">{description}</p>
										<span class="mt-6 inline-flex items-center gap-2 text-sm font-black uppercase tracking-wide text-(--primary)">
											Learn More
											<ArrowRight class="size-4 transition group-hover:translate-x-1" />
										</span>
									</a>
								),
							)
						}
					</div>
				</div>

				<div class="mt-16 lg:mt-20">
					<div class="mb-7 flex items-center gap-4">
						<div class="h-px flex-1 bg-(--border)"></div>
						<h3
							class="text-center text-xs font-black uppercase tracking-[0.2em] text-(--primary) sm:text-sm sm:tracking-[0.22em]"
						>
							Dental Practice Solutions
						</h3>
						<div class="h-px flex-1 bg-(--border)"></div>
					</div>

					<div class="flex flex-wrap justify-center gap-5">
						{
							practiceSolutions.map(
								({ title, href, description, icon: Icon }) => (
									<a
										href={href}
										class="service-card group relative flex w-full flex-col overflow-hidden rounded-4xl p-6 transition hover:-translate-y-1 hover:border-(--primary) md:w-[calc(50%-0.625rem)] md:p-7 xl:w-[calc(25%-0.9375rem)]"
									>
										<Icon class="relative size-10 text-(--primary)" />
										<h4 class="relative mt-6 text-base font-black sm:text-lg">
											{title}
										</h4>
										<p class="relative mt-4 text-sm leading-7 text-(--muted-foreground)">
											{description}
										</p>
										<span class="mt-6 inline-flex items-center gap-2 text-sm font-black uppercase tracking-wide text-(--primary)">
											Learn More
											<ArrowRight class="size-4 transition group-hover:translate-x-1" />
										</span>
									</a>
								),
							)
						}
					</div>
				</div>
			</div>
		</section>

		<!-- PARALLAX FEATURE -->
		<section
			class="relative overflow-hidden bg-site py-20 lg:py-28 xl:py-32"
			style="
				background-image: url('/images/home/dental-practice-bg.webp');
				background-size: cover;
				background-position: center center;
				background-repeat: no-repeat;

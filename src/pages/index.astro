    .service-card {
      position: relative;
      isolation: isolate;
    }

    .service-card::before {
      content: "";
      position: absolute;
      inset: -2px;
      z-index: 0;
      pointer-events: none;
      border-radius: inherit;
      background: linear-gradient(
        115deg,
        transparent 0%,
        transparent 30%,
        rgba(255, 255, 255, 0.08) 42%,
        rgba(239, 35, 49, 0.22) 50%,
        rgba(255, 255, 255, 0.08) 58%,

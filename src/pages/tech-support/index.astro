---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import TrustProofBlock from "../../components/sections/TrustProofBlock.astro";
import { supportedPlatforms } from "../../data/home";

import {
	ArrowRight,
	CheckCircle2,
} from "lucide-astro";

import {
	stats,
	heroImage,
	techSupportServices,
	trustItems,
	introCards,
	whyChoose,
	managedItProofItems,
} from "../../data/tech-support";
---

<MainLayout
	title="Tech Support for Dental Practices in Miami, FL | Dental IT"
	description="Dental IT provides dental-focused tech support in Miami and South Florida, including managed IT support, cloud backups, cloud solutions, endpoint detection and response, HIPAA consulting, cybersecurity, and proactive maintenance."
	image="/images/og/dental-it-miami-home-og.webp"
>
	<main class="overflow-hidden">
		<!-- HERO -->
		<section id="hero" class="relative isolate overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-52 top-16 h-136 w-136 rounded-full bg-(--primary)/18 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-152 w-152 rounded-full bg-(--primary)/14 blur-[170px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.08)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-30"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute top-40 w-full max-w-none blur"
					data-parallax-speed="-0.015"
					data-scroll-opacity-start="0.45"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float absolute bottom-4 w-full max-w-none -translate-x-1/2"
					data-parallax-speed="0.025"
					data-scroll-opacity-start="0.45"
					data-scroll-opacity-end="1000"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float-soft network-float-delay absolute top-10 w-full max-w-none blur"
					data-parallax-speed="-0.018"
					data-scroll-opacity-start="0.12"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/92 via-(--background)/50 to-(--background)/92"
				>
				</div>
			</div>

			<div
				class="site-container grid min-h-[calc(100vh-5rem)] content-center items-center gap-10 py-16 md:py-20 lg:grid-cols-[1.02fr_0.98fr] lg:gap-x-12 lg:gap-y-12 lg:py-24"
			>
				<div class="relative z-10">
					<div
						class="glass-panel inline-flex max-w-full items-center gap-3 rounded-full px-4 py-2"
					>
						<span
							class="inline-flex size-2.5 shrink-0 rounded-full bg-(--primary) shadow-[0_0_18px_rgba(239,35,49,0.95)]"
						></span>

						<span
							class="text-xs font-black uppercase tracking-[0.18em] text-(--foreground) sm:tracking-[0.22em]"
						>
							Tech Support for Dental Practices
						</span>
					</div>

					<h1
						class="mt-7 max-w-5xl text-balance text-[clamp(2.35rem,5.5vw,4.75rem)] font-black leading-[0.95] tracking-tighter"
					>
						Dental tech support built to keep your practice moving.
					</h1>

					<p
						class="mt-7 max-w-2xl text-base leading-8 text-(--muted-foreground) sm:text-lg md:text-xl"
					>
						From managed IT and cloud backups to cybersecurity, HIPAA consulting,
						endpoint protection, and proactive maintenance, Dental IT helps your
						team stay secure, supported, and productive.
					</p>

					<div class="mt-9 flex flex-col gap-4 sm:flex-row">
						<a
							href="/contact"
							class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
						>
							Get Free IT Assessment
							<ArrowRight class="size-4" />
						</a>

						<a
							href="#services"
							class="glass-panel inline-flex items-center justify-center gap-2 rounded-full px-7 py-4 text-sm font-black uppercase tracking-wide text-(--foreground) transition hover:-translate-y-1 hover:border-(--primary) hover:text-(--primary)"
						>
							Explore Tech Support
							<ArrowRight class="size-4" />
						</a>
					</div>

					<div class="mt-10 grid gap-3 sm:grid-cols-2">
						{
							trustItems.slice(0, 4).map((item) => (
								<div class="flex items-start gap-3">
									<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
									<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
										{item}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<div class="relative mx-auto hidden w-full max-w-xl lg:block lg:max-w-none">
					<div class="relative">
						<div class="parallax-layer" data-parallax-speed="0.035">
							<div
								class="glass-panel glass-highlight relative overflow-hidden rounded-4xl p-3 sm:rounded-[2.5rem] sm:p-4"
							>
								<div
									class="relative aspect-[4/4.8] overflow-hidden rounded-3xl sm:rounded-4xl lg:aspect-4/5"
								>
									<Image
                                        src={heroImage.src}
                                        alt={heroImage.alt}
                                        width={heroImage.width}
                                        height={heroImage.height}
                                        format="webp"
                                        quality="high"
                                        class="h-full w-full object-cover"
                                        loading="eager"
                                        decoding="async"
                                    />
								</div>

								<div
									class="absolute inset-x-5 bottom-5 z-20 rounded-2xl border border-white/15 bg-black/55 p-4 text-white shadow-2xl backdrop-blur-2xl sm:inset-x-8 sm:bottom-8 sm:rounded-3xl sm:p-5"
								>
									<p
										class="text-xs font-black uppercase tracking-[0.2em] text-(--primary)"
									>
										Always-On Support
									</p>

									<div class="mt-4 grid grid-cols-3 gap-3">
										<div>
											<p class="text-xl font-black text-white sm:text-2xl">
												24/7
											</p>
											<p class="mt-1 text-[0.7rem] text-white/65 sm:text-xs">
												Monitoring
											</p>
										</div>

										<div>
											<p class="text-xl font-black text-white sm:text-2xl">
												EDR
											</p>
											<p class="mt-1 text-[0.7rem] text-white/65 sm:text-xs">
												Security
											</p>
										</div>

										<div>
											<p class="text-xl font-black text-white sm:text-2xl">
												HIPAA
											</p>
											<p class="mt-1 text-[0.7rem] text-white/65 sm:text-xs">
												Support
											</p>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- HERO STATS PANEL -->
				<div class="relative z-10 mx-auto w-full max-w-6xl lg:col-span-2">
					<div
						class="glass-panel glass-highlight overflow-hidden rounded-4xl border border-(--border)"
					>
						<div
							class="grid grid-cols-1 items-center divide-y divide-(--border) sm:grid-cols-2 sm:divide-x sm:divide-y-0 lg:grid-cols-4"
						>
							{
								stats.map((stat) => (
									<div class="group relative p-6 text-center sm:p-7 lg:p-8">
										<div class="absolute inset-0 bg-(--primary) opacity-0 transition group-hover:opacity-[0.06]" />

										<p class="relative text-[clamp(2rem,5vw,3rem)] font-black leading-none tracking-tighter text-(--foreground)">
											<span class="text-(--primary)">{stat.value}</span>
											{stat.suffix}
										</p>

										<p class="relative mx-auto mt-3 max-w-xs text-sm font-bold leading-6 text-(--muted-foreground)">
											{stat.label}
										</p>
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTRO -->
		<section class="section-padding relative overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-48 top-10 h-112 w-md rounded-full bg-(--primary)/12 blur-[145px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-56 bottom-10 h-128 w-lg rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/86 via-(--background)/45 to-(--background)/92"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div
					class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start xl:gap-10"
				>
					<div class="content-start max-w-4xl text-left">
						<p class="section-eyebrow">
							Dental-Focused IT Help
						</p>

						<h2
							class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
						>
							Support for the systems your team uses every day.
						</h2>

						<div class="site-card mt-8 rounded-4xl p-6 text-left md:p-8 lg:p-9">
							<h3 class="text-xl font-black sm:text-2xl">
								Tech support that understands dental workflows.
							</h3>

							<p class="mt-4 text-base leading-8">
								Your practice depends on workstations, servers, imaging,
								practice management software, backups, cloud tools, cybersecurity,
								and front desk communication. Dental IT helps connect those needs
								into one reliable support strategy for Miami and South Florida
								dental offices.
							</p>
						</div>
					</div>

					<div class="grid gap-5 md:grid-cols-2">
                        {
                            introCards.map(({ title, description, icon: Icon }) => (
                                <div class="site-card rounded-4xl p-6 md:p-7">
                                    <Icon class="size-9 text-(--primary)" />

                                    <h3 class="mt-5 text-lg font-black sm:text-xl">
                                        {title}
                                    </h3>

                                    <p class="mt-4 text-sm leading-7">
                                        {description}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
				</div>
			</div>
		</section>

		<!-- SERVICES -->
		<section id="services" class="section-padding relative overflow-hidden">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-44 top-10 h-120 w-120 rounded-full bg-(--primary)/16 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-48 top-[35%] h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute left-1/2 top-0 h-112 w-md -translate-x-1/2 rounded-full bg-(--primary)/10 blur-[130px]"
				>
				</div>

				<div
					class="parallax-layer absolute w-full max-w-none blur"
					data-parallax-speed="-0.012"
					data-scroll-opacity-start="0.02"
					data-scroll-opacity-end="0.1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float absolute left-1/2 bottom-32 w-432 max-w-none -translate-x-1/2 blur-xs"
					data-parallax-speed="0.018"
					data-scroll-opacity-start="0.08"
					data-scroll-opacity-end="0.28"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/88 via-(--surface)/48 to-(--surface)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow">Tech Support Services</p>

					<h2
						class="section-title mx-auto normal-case text-[clamp(2rem,4.2vw,3.8rem)] leading-none"
					>
						Everything your dental practice needs to stay supported.
					</h2>

					<p class="section-description mx-auto">
						Explore the core Tech Support services Dental IT provides for dental
						practices, including managed support, backups, cloud solutions,
						cybersecurity, endpoint protection, HIPAA consulting, and maintenance.
					</p>
				</div>

				<div class="mt-14 lg:mt-16">
					<div class="mb-7 flex items-center gap-4">
						<div class="h-px flex-1 bg-(--border)"></div>
						<h3
							class="text-center text-xs font-black uppercase tracking-[0.2em] text-(--primary) sm:text-sm sm:tracking-[0.22em]"
						>
							Tech Support
						</h3>
						<div class="h-px flex-1 bg-(--border)"></div>
					</div>

					<div class="flex flex-wrap justify-center gap-5">
						{
							techSupportServices.map(
								({ title, href, description, icon: Icon }) => (
									<a
										href={href}
										class="service-card group relative flex w-full flex-col overflow-hidden rounded-4xl p-6 transition hover:-translate-y-1 hover:border-(--primary) md:w-[calc(50%-0.625rem)] md:p-7 xl:w-[calc(25%-0.9375rem)]"
									>
										<Icon class="relative size-10 text-(--primary)" />
										<h4 class="relative mt-6 text-lg font-black sm:text-xl">
											{title}
										</h4>
										<p class="relative mt-4 text-sm leading-7">
											{description}
										</p>
										<span class="relative mt-6 inline-flex items-center gap-2 text-sm font-black uppercase tracking-wide text-(--primary)">
											Learn More
											<ArrowRight class="size-4 transition group-hover:translate-x-1" />
										</span>
									</a>
								),
							)
						}
					</div>
				</div>
			</div>
		</section>

		<!-- TRUST FEATURE -->
		<section
			class="relative overflow-hidden bg-site py-20 lg:py-28 xl:py-32"
			style="
				background-image: url('/images/home/dental-practice-bg.webp');
				background-size: cover;
				background-position: center center;
				background-repeat: no-repeat;
				background-attachment: fixed;
			"
		>
			<div
				class="pointer-events-none absolute inset-0 z-0 hidden overflow-hidden lg:block"
			>
				<div
					class="absolute inset-0 bg-(--background)/50 dark:bg-black/78"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-br from-(--background)/95 via-(--background)/72 to-(--background)/88 dark:from-black/92 dark:via-black/70 dark:to-black/90"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere absolute -left-44 top-20 h-120 w-120 rounded-full bg-(--primary)/20 blur-[150px]"
					aria-hidden="true"
				>
				</div>
			</div>

			<div
				class="pointer-events-none absolute inset-0 z-0 overflow-hidden lg:hidden"
				aria-hidden="true"
			>
				<div class="absolute inset-0 bg-(--background)/80 dark:bg-black/82">
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/95 via-(--background)/80 to-(--background)/95 dark:from-black/95 dark:via-black/80 dark:to-black/95"
				>
				</div>

				<div
					class="diffuse-sphere absolute -left-40 top-12 h-96 w-96 rounded-full bg-(--primary)/18 blur-[140px]"
				>
				</div>
			</div>

			<div
				class="site-container relative z-10 grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center"
			>
				<div class="relative mx-auto hidden w-full max-w-xl lg:block lg:max-w-none">
					<div
						class="grid gap-5 sm:grid-cols-2 lg:block lg:min-h-136 xl:min-h-152"
					>
						<div
							class="parallax-layer lg:absolute lg:left-0 lg:top-0 lg:w-[80%]"
							data-parallax-speed="0.04"
						>
							<div class="glass-panel rounded-4xl p-3">
								<Image
									src="/images/home/miami-dental-practice-it-support-team.webp"
									alt="Dental IT support team helping a Miami dental practice"
									width={1200}
									height={1500}
									format="webp"
									quality="high"
									class="aspect-4/5 w-full rounded-3xl object-cover"
									loading="lazy"
									decoding="async"
								/>
							</div>
						</div>

						<div
							class="parallax-layer lg:absolute lg:bottom-0 lg:right-0 lg:w-[80%]"
							data-parallax-speed="-0.035"
						>
							<div class="glass-panel rounded-4xl p-3">
								<Image
									src="/images/home/dental-office-cybersecurity-monitoring-miami.webp"
									alt="Cybersecurity and monitoring for a dental office in Miami"
									width={1200}
									height={1500}
									format="webp"
									quality="high"
									class="aspect-4/5 w-full rounded-3xl object-cover"
									loading="lazy"
									decoding="async"
								/>
							</div>
						</div>
					</div>
				</div>

				<div>
					<p class="section-eyebrow">Why Dental Clinics Trust Us</p>

					<h2
						class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
					>
						Technology support designed around patient care.
					</h2>

					<p class="section-description">
						Downtime, security incidents, slow workstations, failed backups, and
						disconnected systems can interrupt the patient experience. Dental IT
						helps your team stay focused, productive, and protected.
					</p>

					<div class="mt-9 grid gap-4">
						{
							whyChoose.map(({ title, description, icon: Icon }) => (
								<div class="glass-panel glass-highlight flex gap-5 rounded-4xl p-5 sm:p-6">
									<div class="relative flex size-12 shrink-0 items-center justify-center rounded-2xl bg-(--primary) text-white">
										<Icon class="size-6" />
									</div>

									<div class="relative">
										<h3 class="text-base font-black text-(--foreground) sm:text-lg">
											{title}
										</h3>
										<p class="mt-2 text-sm leading-7 text-(--muted-foreground)">
											{description}
										</p>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<TrustProofBlock
			eyebrow="Managed IT Trust Points"
			title="IT support built around the systems dental practices depend on."
			description="Dental IT focuses on practical support, monitoring, maintenance, security, backups, and dental-specific workflows instead of generic business IT."
			platforms={supportedPlatforms}
			proofItems={managedItProofItems}
		/>

	</main>

	<script>
		const serviceCards = document.querySelectorAll(".service-card");

		serviceCards.forEach((card) => {
			card.addEventListener("pointermove", (event) => {
				const rect = card.getBoundingClientRect();
				const x = ((event.clientX - rect.left) / rect.width) * 100;
				const y = ((event.clientY - rect.top) / rect.height) * 100;

				card.style.setProperty("--service-card-x", `${x}%`);
				card.style.setProperty("--service-card-y", `${y}%`);
			});

			card.addEventListener("pointerleave", () => {
				card.style.removeProperty("--service-card-x");
				card.style.removeProperty("--service-card-y");
			});
		});

		const parallaxLayers = document.querySelectorAll("[data-parallax-speed]");
		const scrollOpacityLayers = document.querySelectorAll(".network-scroll-opacity");
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

		const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

		const updateScrollOpacity = () => {
			const scrollY = window.scrollY;
			const viewportHeight = window.innerHeight || 1;

			scrollOpacityLayers.forEach((layer) => {
				const startOpacity = Number(
					layer.getAttribute("data-scroll-opacity-start") || 0.08,
				);
				const endOpacity = Number(
					layer.getAttribute("data-scroll-opacity-end") || 0.45,
				);

				const fadeDistance = viewportHeight * 0.85;
				const progress = clamp(scrollY / fadeDistance, 0, 1);
				const opacity = startOpacity + (endOpacity - startOpacity) * progress;

				layer.style.setProperty("--network-scroll-opacity", String(opacity));
			});
		};

		const resetParallax = () => {
			parallaxLayers.forEach((layer) => {
				layer.style.removeProperty("--parallax-y");
				layer.style.transform = "";
			});
		};

		const updateParallax = () => {
			updateScrollOpacity();

			if (reduceMotion.matches || window.innerWidth < 1024) return;

			const scrollY = window.scrollY;

			parallaxLayers.forEach((layer) => {
				const speed = Number(layer.getAttribute("data-parallax-speed") || 0);
				const y = scrollY * speed;

				layer.style.setProperty("--parallax-y", `${y}px`);
				layer.style.transform = `translate3d(0, var(--parallax-y), 0)`;
			});
		};

		const handleParallax = () => {
			updateScrollOpacity();

			if (reduceMotion.matches || window.innerWidth < 1024) {
				resetParallax();
				return;
			}

			updateParallax();
		};

		handleParallax();

		window.addEventListener("scroll", handleParallax, { passive: true });
		window.addEventListener("resize", handleParallax);
	</script>


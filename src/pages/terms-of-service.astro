---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import { ArrowRight, CheckCircle2, FileText, Scale } from "lucide-astro";

import {
	lastUpdated,
	termsHighlights,
	termsSections,
	contactInfo,
} from "../data/terms-of-service";
---

<MainLayout
	title="Terms of Service | Dental IT"
	description="Read Dental IT's Terms of Service for website use, service information, user responsibilities, disclaimers, and related terms."
	image="/images/og/dental-it-miami-home-og.webp"
>
	<main class="overflow-hidden">
		<!-- HERO -->
		<section class="relative isolate overflow-hidden bg-site">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-52 top-16 h-136 w-136 rounded-full bg-(--primary)/18 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-152 w-152 rounded-full bg-(--primary)/14 blur-[170px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.08)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-30"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute top-40 w-full max-w-none blur"
					data-parallax-speed="-0.015"
					data-scroll-opacity-start="0.45"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float absolute bottom-4 w-full max-w-none -translate-x-1/2"
					data-parallax-speed="0.025"
					data-scroll-opacity-start="0.45"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float-soft network-float-delay absolute top-10 w-full max-w-none blur"
					data-parallax-speed="-0.018"
					data-scroll-opacity-start="0.12"
					data-scroll-opacity-end="1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full"
						loading="eager"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/92 via-(--background)/55 to-(--background)/94"
				>
				</div>
			</div>

			<div
				class="site-container grid min-h-[calc(100vh-5rem)] items-center gap-12 py-16 md:py-20 lg:grid-cols-[1.02fr_0.98fr] lg:py-24"
			>
				<div class="relative z-10">
					<div
						class="glass-panel inline-flex max-w-full items-center gap-3 rounded-full px-4 py-2"
					>
						<span
							class="inline-flex size-2.5 shrink-0 rounded-full bg-(--primary) shadow-[0_0_18px_rgba(239,35,49,0.95)]"
						></span>

						<span
							class="text-xs font-black uppercase tracking-[0.18em] text-(--foreground) sm:tracking-[0.22em]"
						>
							Terms of Service
						</span>
					</div>

					<h1
						class="mt-7 max-w-5xl text-balance text-[clamp(2.4rem,5.8vw,5rem)] font-black leading-[0.95] tracking-tighter"
					>
						Website terms for using Dental IT online.
					</h1>

					<p
						class="mt-7 max-w-2xl text-base leading-8 text-(--muted-foreground) sm:text-lg md:text-xl"
					>
						These Terms of Service explain the rules and conditions that apply
						when you access our website, review our service information, or
						contact Dental IT through online forms.
					</p>

					<p class="mt-5 text-sm font-bold text-(--muted-foreground)">
						Last updated: {lastUpdated}
					</p>

					<div class="mt-9 flex flex-col gap-4 sm:flex-row">
						<a
							href="/contact"
							class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-7 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
						>
							Contact Dental IT
							<ArrowRight class="size-4" />
						</a>

						<a
							href="#terms-of-service"
							class="glass-panel inline-flex items-center justify-center gap-2 rounded-full px-7 py-4 text-sm font-black uppercase tracking-wide text-(--foreground) transition hover:-translate-y-1 hover:border-(--primary) hover:text-(--primary)"
						>
							Read Terms
							<ArrowRight class="size-4" />
						</a>
					</div>

					<div class="mt-10 grid gap-3 sm:grid-cols-2">
						{
							termsHighlights.map((item) => (
								<div class="flex items-start gap-3">
									<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
									<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
										{item}
									</p>
								</div>
							))
						}
					</div>
				</div>

				<div
					class="relative mx-auto hidden w-full max-w-xl lg:block lg:max-w-none"
				>
					<div class="glass-panel glass-highlight rounded-4xl p-8 xl:p-10">
						<div class="relative">
							<div
								class="inline-flex items-center justify-center rounded-full bg-(--primary) p-3 text-white shadow-[0_0_18px_rgba(239,35,49,0.95)]"
							>
								<Scale class="size-8" />
							</div>

							<h2 class="mt-8 text-3xl font-black tracking-tighter xl:text-4xl">
								Clear terms for website use and service inquiries.
							</h2>

							<p class="mt-5 text-base leading-8 text-(--muted-foreground)">
								Our website helps dental practices learn about Dental IT services,
								request consultations, and contact our team. These terms explain
								how the website should be used and where separate service
								agreements may apply.
							</p>

							<div class="mt-8 grid gap-4">
								<div class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl">
									<p class="text-sm font-black uppercase tracking-[0.18em] text-(--primary)">
										Important
									</p>
									<p class="mt-3 text-sm leading-7 text-(--muted-foreground)">
										Website content is informational and does not replace a
										written service agreement, proposal, or statement of work.
									</p>
								</div>

								<div class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl">
									<p class="text-sm font-black uppercase tracking-[0.18em] text-(--primary)">
										Service Requests
									</p>
									<p class="mt-3 text-sm leading-7 text-(--muted-foreground)">
										Existing clients should use their designated support channels
										for urgent technical issues or service-impacting problems.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- TERMS OVERVIEW -->
		<section class="section-padding relative overflow-hidden bg-surface">
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="absolute inset-0 bg-linear-to-br from-(--surface)/78 via-(--surface)/45 to-(--surface)/72 dark:from-black/78 dark:via-black/48 dark:to-black/82"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere absolute -left-48 top-10 h-112 w-md rounded-full bg-(--primary)/12 blur-[145px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-52 bottom-10 h-136 w-136 rounded-full bg-(--primary)/14 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.06)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-85"
					aria-hidden="true"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute left-1/2 top-12 w-432 max-w-none -translate-x-1/2 blur-2xl"
					data-parallax-speed="-0.012"
					data-scroll-opacity-start="0.03"
					data-scroll-opacity-end="0.12"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-260"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--surface)/90 via-(--surface)/50 to-(--surface)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
					<div>
						<p class="section-eyebrow">Website Terms</p>

						<h2
							class="section-title normal-case text-[clamp(2rem,4vw,3.6rem)] leading-none"
						>
							A practical framework for using this website.
						</h2>

						<p class="section-description">
							These Terms apply to general website use, online inquiries, and
							access to Dental IT website content. Actual IT services may be
							governed by separate written agreements, proposals, or statements
							of work.
						</p>

						<div class="mt-8 grid gap-3">
							{
								termsHighlights.map((item) => (
									<div class="flex items-start gap-3">
										<CheckCircle2 class="mt-1 size-5 shrink-0 text-(--primary)" />
										<p class="text-sm font-bold leading-6 text-(--muted-foreground)">
											{item}
										</p>
									</div>
								))
							}
						</div>
					</div>

					<div
						class="glass-panel glass-highlight rounded-4xl p-6 sm:p-8 lg:p-10"
					>
						<div class="relative">
							<FileText class="size-10 text-(--primary)" />

							<h3 class="mt-6 text-2xl font-black tracking-tighter sm:text-3xl">
								Service details should always be confirmed in writing.
							</h3>

							<p class="mt-5 text-base leading-8 text-(--muted-foreground)">
								The website explains what Dental IT offers, but project scope,
								service levels, pricing, responsibilities, and deliverables should
								be documented in the appropriate written agreement before work
								begins.
							</p>

							<div class="mt-7 rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl">
								<p class="text-sm font-black uppercase tracking-[0.18em] text-(--primary)">
									Legal Review Recommended
								</p>
								<p class="mt-3 text-sm leading-7 text-(--muted-foreground)">
									This terms copy is provided as a practical website draft and
									should be reviewed by legal counsel before publication.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FULL TERMS -->
		<section
			id="terms-of-service"
			class="section-padding relative overflow-hidden bg-site"
		>
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-44 top-10 h-120 w-120 rounded-full bg-(--primary)/16 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-48 top-[20%] h-136 w-136 rounded-full bg-(--primary)/10 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="absolute left-1/2 top-0 h-112 w-md -translate-x-1/2 rounded-full bg-(--primary)/10 blur-[130px]"
				>
				</div>

				<div
					class="parallax-layer absolute w-full max-w-none blur"
					data-parallax-speed="-0.012"
					data-scroll-opacity-start="0.02"
					data-scroll-opacity-end="0.1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="parallax-layer network-float absolute left-1/2 top-52 w-432 max-w-none -translate-x-1/2"
					data-parallax-speed="0.018"
					data-scroll-opacity-start="0.08"
					data-scroll-opacity-end="0.28"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-280"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--background)/90 via-(--background)/58 to-(--background)/94"
				>
				</div>
			</div>

			<div class="site-container relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="section-eyebrow justify-center">Full Terms of Service</p>

					<h2
						class="section-title mx-auto normal-case text-[clamp(2rem,4.2vw,3.8rem)] leading-none"
					>
						Terms that apply to this website.
					</h2>

					<p class="section-description mx-auto">
						The sections below explain website use, service information, user
						responsibilities, intellectual property, disclaimers, limitations,
						and how to contact Dental IT with questions.
					</p>
				</div>

				<div class="mx-auto mt-12 max-w-7xl">
					<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
						{
							termsSections.map((section) => (
								<article class="glass-panel glass-highlight rounded-4xl p-6 sm:p-8">
									<h3 class="text-lg font-black tracking-tight text-(--foreground)">
										{section.title}
									</h3>

									<div class="mt-5 grid gap-4">
										{section.content.map((paragraph) => (
											<p class="text-sm leading-7 text-(--muted-foreground) sm:text-base sm:leading-8">
												{paragraph}
											</p>
										))}
									</div>
								</article>
							))
						}

						<article class="glass-panel glass-highlight rounded-4xl p-6 sm:p-8 md:col-span-2 xl:col-span-3">
							<h3 class="text-xl font-black tracking-tight text-(--foreground) sm:text-2xl">
								13. Contact Us
							</h3>

							<p class="mt-5 text-sm leading-7 text-(--muted-foreground) sm:text-base sm:leading-8">
								If you have questions about these Terms of Service, website use,
								or Dental IT services, please contact us.
							</p>

							<div class="mt-6 grid gap-4 sm:grid-cols-2">
								{
									contactInfo.map((item) => (
										<a
											href={item.href}
											class="rounded-3xl border border-(--border) bg-(--card)/70 p-5 backdrop-blur-xl transition hover:-translate-y-1 hover:border-(--primary)"
										>
											<p class="text-xs font-black uppercase tracking-[0.18em] text-(--primary)">
												{item.label}
											</p>
											<p class="mt-2 text-base font-black text-(--foreground)">
												{item.value}
											</p>
										</a>
									))
								}
							</div>
						</article>
					</div>
				</div>
			</div>
		</section>

		<!-- FINAL CTA -->
		<section
			class="relative overflow-hidden bg-footer py-16 text-(--footer-foreground) md:py-20 lg:py-28"
		>
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div
					class="diffuse-sphere absolute -left-48 top-0 h-120 w-120 rounded-full bg-(--primary)/18 blur-[150px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="diffuse-sphere diffuse-sphere-delay absolute -right-48 bottom-0 h-136 w-136 rounded-full bg-(--primary)/14 blur-[160px]"
					aria-hidden="true"
				>
				</div>

				<div
					class="network-scroll-opacity parallax-layer absolute left-1/2 -bottom-16 w-432 max-w-none -translate-x-1/2 blur-2xl"
					data-parallax-speed="-0.012"
					data-scroll-opacity-start="0.03"
					data-scroll-opacity-end="0.1"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-260"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="network-scroll-opacity parallax-layer network-float absolute left-1/2 -bottom-12 w-400 max-w-none -translate-x-1/2 blur-4xl"
					data-parallax-speed="0.015"
					data-scroll-opacity-start="0.06"
					data-scroll-opacity-end="0.2"
					aria-hidden="true"
				>
					<Image
						src="/images/backgrounds/dental-it-network-bg.png"
						alt=""
						width={2048}
						height={620}
						class="w-full min-w-260"
						loading="lazy"
						decoding="async"
					/>
				</div>

				<div
					class="absolute inset-0 bg-linear-to-b from-(--footer-background)/88 via-(--footer-background)/45 to-(--footer-background)/95"
				>
				</div>
			</div>

			<div
				class="absolute inset-0 bg-[linear-gradient(to_right,rgba(127,127,127,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(127,127,127,0.06)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-85"
				aria-hidden="true"
			>
			</div>

			<div class="site-container relative">
				<div
					class="glass-panel glass-highlight mx-auto max-w-5xl rounded-4xl p-6 text-center sm:p-8 md:rounded-[2.5rem] md:p-12 lg:p-16"
				>
					<p class="section-eyebrow justify-center">Need Clarification?</p>

					<h2
						class="mt-5 text-[clamp(2rem,4.2vw,3.75rem)] font-black leading-none tracking-tighter text-(--footer-foreground)"
					>
						Contact Dental IT about these terms or your service request.
					</h2>

					<p
						class="mx-auto mt-6 max-w-3xl text-base leading-8 text-(--footer-muted) md:text-lg"
					>
						If you have questions about website use, service agreements, or how
						to contact Dental IT securely, reach out to our team directly.
					</p>

					<div class="mt-9 flex flex-col justify-center gap-4 sm:flex-row">
						<a
							href="/contact"
							class="inline-flex items-center justify-center gap-2 rounded-full bg-(--primary) px-8 py-4 text-sm font-black uppercase tracking-wide text-white shadow-[0_18px_42px_rgba(239,35,49,0.32)] transition hover:-translate-y-1 hover:bg-(--primary-hover)"
						>
							Contact Us
							<ArrowRight class="size-4" />
						</a>

						<a
							href="tel:+13059725760"
							class="glass-panel inline-flex items-center justify-center gap-2 rounded-full px-8 py-4 text-sm font-black uppercase tracking-wide text-(--footer-foreground) transition hover:-translate-y-1 hover:border-(--primary) hover:text-(--primary)"
						>
							Call (305) 972-5760
							<ArrowRight class="size-4" />
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<style>
		@keyframes floatY {
			0%,
			100% {
				transform: translateY(0);
			}

			50% {
				transform: translateY(-14px);
			}
		}

		@keyframes networkFloat {
			0%,
			100% {
				translate: 0 0;
			}

			50% {
				translate: 0 -22px;
			}
		}

		@keyframes networkFloatSoft {
			0%,
			100% {
				translate: 0 0;
				opacity: 0.16;
			}

			50% {
				translate: 0 -18px;
				opacity: 0.28;
			}
		}

		@keyframes diffusePulse {
			0%,
			100% {
				transform: scale(1);
				opacity: 0.75;
			}

			50% {
				transform: scale(1.08);
				opacity: 1;
			}
		}

		.floating-card {
			animation: floatY 6s ease-in-out infinite;
		}

		.floating-card-alt {
			animation: floatY 7s ease-in-out infinite;
			animation-delay: -2.5s;
		}

		.network-float {
			animation: networkFloat 9s ease-in-out infinite;
			will-change: translate, transform;
		}

		.network-float-soft {
			animation: networkFloatSoft 11s ease-in-out infinite;
			will-change: translate, opacity, transform;
		}

		.network-float-delay {
			animation-delay: -4s;
		}

		.network-scroll-opacity {
			opacity: var(--network-scroll-opacity, 1);
			transition: opacity 1500ms linear;
			will-change: opacity, transform;
		}

		.diffuse-sphere {
			animation: diffusePulse 10s ease-in-out infinite;
			will-change: transform, opacity;
		}

		.diffuse-sphere-delay {
			animation-delay: -5s;
		}

		@media (max-width: 1279px) {
			.floating-card,
			.floating-card-alt {
				animation: none;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.floating-card,
			.floating-card-alt,
			.network-float,
			.network-float-soft,
			.diffuse-sphere {
				animation: none;
			}

			.network-scroll-opacity {
				transition: none;
			}
		}
	</style>

	<script>
		const parallaxLayers = document.querySelectorAll("[data-parallax-speed]");
		const scrollOpacityLayers = document.querySelectorAll(".network-scroll-opacity");
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

		const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

		const updateScrollOpacity = () => {
			const scrollY = window.scrollY;
			const viewportHeight = window.innerHeight || 1;

			scrollOpacityLayers.forEach((layer) => {
				const startOpacity = Number(
					layer.getAttribute("data-scroll-opacity-start") || 0.08,
				);
				const endOpacity = Number(
					layer.getAttribute("data-scroll-opacity-end") || 0.45,
				);

				const fadeDistance = viewportHeight * 0.85;
				const progress = clamp(scrollY / fadeDistance, 0, 1);
				const opacity = startOpacity + (endOpacity - startOpacity) * progress;

				layer.style.setProperty("--network-scroll-opacity", String(opacity));
			});
		};

		const updateParallax = () => {
			updateScrollOpacity();

			if (reduceMotion.matches || window.innerWidth < 1024) return;

			const scrollY = window.scrollY;

			parallaxLayers.forEach((layer) => {
				const speed = Number(layer.getAttribute("data-parallax-speed") || 0);
				const y = scrollY * speed;

				layer.style.setProperty("--parallax-y", `${y}px`);
				layer.style.transform = `translate3d(0, var(--parallax-y), 0)`;
			});
		};

		const resetParallax = () => {
			parallaxLayers.forEach((layer) => {
				layer.style.removeProperty("--parallax-y");
				layer.style.transform = "";
			});
		};

		const handleParallax = () => {
			updateScrollOpacity();

			if (reduceMotion.matches || window.innerWidth < 1024) {
				resetParallax();
				return;
			}

			updateParallax();
		};

		handleParallax();

		window.addEventListener("scroll", handleParallax, { passive: true });
		window.addEventListener("resize", handleParallax);
	</script>
</MainLayout>